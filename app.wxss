/* ===== 全局样式 — Claymorphism + 暖陶土配色 ===== */
/* 设计规范参考 ui-ux-pro-max: Recipe & Cooking App */

page {
  background-color: #FFFBEB;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #3D2C1E;
  box-sizing: border-box;
}

/* 卡片 — Claymorphism 双层阴影 */
.card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 28rpx;
  margin: 0 24rpx 20rpx;
  border: 2rpx solid #F2E6E2;
  box-shadow:
    0 4rpx 8rpx rgba(154, 52, 18, 0.04),
    0 12rpx 24rpx rgba(154, 52, 18, 0.06);
}

/* 主按钮 — 暖陶土渐变 */
.btn-primary {
  background: linear-gradient(135deg, #C2410C, #EA580C);
  color: #fff;
  border-radius: 24rpx;
  padding: 22rpx 44rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx solid rgba(255,255,255,0.2);
  box-shadow:
    0 4rpx 8rpx rgba(194, 65, 12, 0.2),
    0 12rpx 20rpx rgba(194, 65, 12, 0.15);
}

/* 次按钮 — 清新绿渐变 */
.btn-secondary {
  background: linear-gradient(135deg, #059669, #10B981);
  color: #fff;
  border-radius: 24rpx;
  padding: 22rpx 44rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx solid rgba(255,255,255,0.2);
  box-shadow:
    0 4rpx 8rpx rgba(5, 150, 105, 0.2),
    0 12rpx 20rpx rgba(5, 150, 105, 0.15);
}

.btn-primary:active, .btn-secondary:active {
  opacity: 0.85;
  transform: scale(0.97);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #8B7355;
  font-size: 28rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  background: #FEF3C7;
  color: #92400E;
  margin-right: 8rpx;
  border: 1rpx solid #FDE68A;
}

.tag-active {
  background: linear-gradient(135deg, #C2410C, #EA580C);
  color: #fff;
  border: none;
}

/* 手绘占位图 */
.hand-drawn-placeholder {
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
  border: 3rpx dashed #D97706;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
