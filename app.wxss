/* ===== 全局设计系统 — Bento Grid Modern ===== */
/* 深蓝黑 + 暖白 + 赤红点缀 */

page {
  background-color: #F5F5F7;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1a1a2e;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 0 24rpx 20rpx;
  box-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.04),
    0 8rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* 主按钮 — 赤红 */
.btn-primary {
  background: #e94560;
  color: #fff;
  border-radius: 16rpx;
  padding: 22rpx 44rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(233, 69, 96, 0.3);
}

.btn-primary:active {
  transform: scale(0.96);
}

/* 次按钮 — 深蓝描边 */
.btn-secondary {
  background: transparent;
  color: #0f3460;
  border-radius: 16rpx;
  padding: 22rpx 44rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid #0f3460;
}

.btn-secondary:active {
  transform: scale(0.96);
  background: rgba(15, 52, 96, 0.06);
}

/* 标签 */
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  background: rgba(233, 69, 96, 0.08);
  color: #e94560;
  margin-right: 8rpx;
  font-weight: 500;
}

.tag-active {
  background: #e94560;
  color: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  color: #8a8f98;
  font-size: 28rpx;
}

/* 手绘占位图 */
.hand-drawn-placeholder {
  background: #F5F5F7;
  border: 3rpx dashed #d1d5db;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
