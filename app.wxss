/* ===== 全局设计系统 — 大厂风格统一规范 ===== */

page {
  background-color: #F8F9FA;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #2D3436;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
}

/* 卡片 */
.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 0 24rpx 20rpx;
  box-shadow:
    0 2rpx 8rpx rgba(0, 0, 0, 0.04),
    0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

/* 主按钮 — 珊瑚红 */
.btn-primary {
  background: #E94560;
  color: #fff;
  border-radius: 28rpx;
  padding: 22rpx 44rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(233, 69, 96, 0.25);
}

.btn-primary:active { transform: scale(0.96); }

/* 次按钮 — 翡翠绿描边 */
.btn-secondary {
  background: transparent;
  color: #4ECDC4;
  border-radius: 28rpx;
  padding: 22rpx 44rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  border: 2rpx solid #4ECDC4;
}

.btn-secondary:active { transform: scale(0.96); background: rgba(78, 205, 196, 0.06); }

/* 标签 */
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  background: rgba(233, 69, 96, 0.08);
  color: #E94560;
  margin-right: 8rpx;
  font-weight: 500;
}

.tag-active {
  background: #E94560;
  color: #fff;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-emoji { font-size: 80rpx; margin-bottom: 20rpx; opacity: 0.5; }

.empty-text { color: #636E72; font-size: 28rpx; }

/* 手绘占位图 */
.hand-drawn-placeholder {
  background: #F8F9FA;
  border: 3rpx dashed #DFE6E9;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 骨架屏 */
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.skeleton {
  background: linear-gradient(90deg, #E8E8EC 25%, #F8F9FA 50%, #E8E8EC 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 12rpx;
}
