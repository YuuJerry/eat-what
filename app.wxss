/* ===== 全局样式 — 星巴克设计语言 ===== */
/* 来源: awesome-design-md/starbucks/DESIGN.md */

page {
  background-color: #f2f0eb;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.87);
  box-sizing: border-box;
  letter-spacing: -0.01em;
}

/* 卡片 — 12px 圆角 + 星巴克式柔和阴影 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 0 24rpx 20rpx;
  box-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.06),
    0 8rpx 16rpx rgba(0, 0, 0, 0.08);
}

/* 主按钮 — 星巴克绿胶囊 */
.btn-primary {
  background: #00754A;
  color: #ffffff;
  border-radius: 100rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: -0.01em;
  border: 2rpx solid #00754A;
  transition: all 0.2s ease;
}

.btn-primary:active {
  transform: scale(0.95);
}

/* 次按钮 — 描边绿胶囊 */
.btn-secondary {
  background: transparent;
  color: #00754A;
  border-radius: 100rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: -0.01em;
  border: 2rpx solid #00754A;
}

.btn-secondary:active {
  transform: scale(0.95);
  background: rgba(0, 117, 74, 0.06);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  color: rgba(0, 0, 0, 0.58);
  font-size: 28rpx;
}

/* 标签 — 星巴克风格 */
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  background: #d4e9e2;
  color: #1E3932;
  margin-right: 8rpx;
  font-weight: 500;
}

.tag-active {
  background: #00754A;
  color: #ffffff;
}

/* 手绘占位图 */
.hand-drawn-placeholder {
  background: #f2f0eb;
  border: 3rpx dashed #d6dbde;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 文字颜色系统 */
.text-primary { color: rgba(0, 0, 0, 0.87); }
.text-secondary { color: rgba(0, 0, 0, 0.58); }
.text-white { color: #ffffff; }
.text-white-soft { color: rgba(255, 255, 255, 0.70); }
.text-green { color: #006241; }
.text-gold { color: #cba258; }
