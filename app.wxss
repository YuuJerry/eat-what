/* 全局页面基础样式 */
page {
  background-color: #FFF5F5; /* 浅粉背景色 */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box; /* 统一盒模型，padding 不会撑大元素 */
}

/* 全局卡片容器样式 */
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 0 24rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06); /* 轻微阴影，增强层次感 */
}

/* 主按钮样式（渐变红色） */
.btn-primary {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  color: #fff;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.3);
}

/* 次按钮样式（渐变青绿色） */
.btn-secondary {
  background: linear-gradient(135deg, #4ECDC4, #6EE7DE);
  color: #fff;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 20rpx rgba(78, 205, 196, 0.3);
}

/* 按钮按下时的反馈效果 */
.btn-primary:active, .btn-secondary:active {
  opacity: 0.85;    /* 降低透明度 */
  transform: scale(0.97); /* 轻微缩小 */
}

/* 空状态布局（无数据时的占位提示） */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

/* 空状态图标/表情 */
.empty-emoji {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

/* 空状态提示文字 */
.empty-text {
  color: #999;
  font-size: 28rpx;
}

/* 通用标签样式（用于分类、筛选等） */
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  color: #999;
  margin-right: 8rpx;
}

/* 标签激活状态（选中时） */
.tag-active {
  background: #FF6B6B;
  color: #fff;
}

/* 手绘风格占位图容器（用于无图片时的替代显示） */
.hand-drawn-placeholder {
  background: linear-gradient(135deg, #FFE5D9, #FFD7D7);
  border: 3rpx dashed #FFB3B3; /* 虚线边框，增强手绘感 */
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  filter: contrast(0.95) saturate(1.1); /* 微调对比度和饱和度 */
}
