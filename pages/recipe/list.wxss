/* ========================================
   菜谱列表页 — 完整样式
   ======================================== */

.page {
  min-height: 100vh;
  background: #F5F6FA;
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

/* ── 搜索条 ──────────────────────────── */

.search-bar {
  display: flex;
  align-items: center;
  margin: 24rpx 28rpx 0;
  padding: 18rpx 24rpx;
  background: #1A1A2E;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 26, 46, 0.18);
}

/* CSS 搜索图标 */
.search-icon-wrap {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  flex-shrink: 0;
}
.search-icon-circle {
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.45);
  border-radius: 50%;
  position: relative;
  box-sizing: border-box;
}
.search-icon-handle {
  position: absolute;
  bottom: -8rpx;
  right: -6rpx;
  width: 10rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.45);
  border-radius: 2rpx;
  transform: rotate(45deg);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #FFFFFF;
  background: transparent;
  height: 48rpx;
  line-height: 48rpx;
}
.search-placeholder {
  color: rgba(255, 255, 255, 0.35);
  font-size: 28rpx;
}

.search-go {
  margin-left: 16rpx;
  padding: 10rpx 28rpx;
  background: #E94560;
  border-radius: 14rpx;
  flex-shrink: 0;
}
.search-go text {
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 600;
}

/* ── 分类标签 ──────────────────────────── */

.cat-scroll {
  padding: 24rpx 28rpx 8rpx;
  white-space: nowrap;
}

.cat-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 36rpx;
  margin-right: 18rpx;
  border-radius: 100rpx;
  background: #FFFFFF;
  border: 2rpx solid #E2E6EA;
  font-size: 26rpx;
  color: #636E72;
  font-weight: 500;
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
.cat-pill:last-child {
  margin-right: 0;
}
.cat-pill.active {
  background: #E94560;
  border-color: #E94560;
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(233, 69, 96, 0.3);
}

/* ── 提示文字 ──────────────────────────── */

.hint {
  text-align: center;
  padding: 16rpx 0 20rpx;
}
.hint-text {
  font-size: 24rpx;
  color: #A0A4A8;
  letter-spacing: 2rpx;
}

/* ── 菜谱网格 ──────────────────────────── */

.recipe-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 0 28rpx;
}

.recipe-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow:
    0 2rpx 8rpx rgba(0, 0, 0, 0.03),
    0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.15s ease;
}
.recipe-card:active {
  transform: scale(0.97);
}

.card-media {
  position: relative;
  width: 100%;
  height: 220rpx;
  background: linear-gradient(135deg, #F0F2F5 0%, #E8EBF0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.card-img {
  width: 130rpx;
  height: 130rpx;
}

/* 轻食角标 */
.card-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  padding: 6rpx 18rpx;
  background: #4ECDC4;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 100rpx;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 12rpx rgba(78, 205, 196, 0.35);
}

/* 卡片文字区域 */
.card-body {
  padding: 18rpx 20rpx 22rpx;
}
.card-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}
.card-meta {
  display: block;
  font-size: 24rpx;
  color: #A0A4A8;
  line-height: 1.3;
}

/* ── 骨架屏 ──────────────────────────── */

.skeleton-card {
  pointer-events: none;
}

.skeleton {
  background: linear-gradient(
    90deg,
    #E8E8EC 25%,
    #F2F2F5 37%,
    #E8E8EC 63%
  );
  background-size: 400% 100%;
  animation: skeleton-shimmer 1.4s ease infinite;
  border-radius: 8rpx;
}
.skel-img {
  width: 100%;
  height: 220rpx;
  border-radius: 0;
}
.skel-line {
  height: 28rpx;
  margin: 14rpx 20rpx 0;
  border-radius: 6rpx;
}
.skel-line.short {
  width: 55%;
  margin-bottom: 22rpx;
}

@keyframes skeleton-shimmer {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}

/* ── 空状态 ──────────────────────────── */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx 0;
}

/* CSS 碗图标 */
.empty-icon {
  position: relative;
  width: 120rpx;
  height: 80rpx;
  margin-bottom: 36rpx;
}
.empty-bowl {
  width: 120rpx;
  height: 70rpx;
  background: #E8EBF0;
  border-radius: 0 0 60rpx 60rpx;
  position: absolute;
  bottom: 0;
}
.empty-bowl::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: -8rpx;
  width: 136rpx;
  height: 20rpx;
  background: #D5D9DE;
  border-radius: 10rpx;
}
.empty-steam {
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 6rpx;
  height: 24rpx;
  background: rgba(160, 164, 168, 0.4);
  border-radius: 3rpx;
  animation: steam-float 2s ease-in-out infinite;
}
.empty-steam::before,
.empty-steam::after {
  content: '';
  position: absolute;
  width: 6rpx;
  height: 20rpx;
  background: rgba(160, 164, 168, 0.3);
  border-radius: 3rpx;
}
.empty-steam::before {
  left: -16rpx;
  top: 4rpx;
  animation: steam-float 2s ease-in-out 0.3s infinite;
}
.empty-steam::after {
  left: 16rpx;
  top: -2rpx;
  animation: steam-float 2s ease-in-out 0.6s infinite;
}

@keyframes steam-float {
  0%, 100% {
    opacity: 0.3;
    transform: translateY(0);
  }
  50% {
    opacity: 0.7;
    transform: translateY(-8rpx);
  }
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #636E72;
  margin-bottom: 10rpx;
}
.empty-sub {
  font-size: 26rpx;
  color: #A0A4A8;
}
