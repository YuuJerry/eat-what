/* 菜谱列表 — 统一设计系统 */

.page { background: #F8F9FA; min-height: 100vh; padding-bottom: 120rpx; }

/* 搜索条 */
.search-section { padding: 20rpx 24rpx 12rpx; }
.search-bar {
  display: flex; align-items: center; gap: 10rpx;
  background: #1A1A2E; border-radius: 16rpx; padding: 16rpx 20rpx;
}
.search-icon { font-size: 26rpx; opacity: 0.5; }
.search-input { flex: 1; font-size: 26rpx; color: #fff; background: transparent; }
.search-input::placeholder { color: rgba(255,255,255,0.35); }
.search-go {
  background: #E94560; border-radius: 12rpx; padding: 8rpx 20rpx;
}
.search-go text { font-size: 24rpx; color: #fff; font-weight: 500; }

/* 分类标签 */
.cat-scroll { padding: 12rpx 24rpx; white-space: nowrap; }
.cat-pill {
  display: inline-flex; padding: 10rpx 24rpx; margin-right: 12rpx;
  border-radius: 100rpx; background: #fff; border: 2rpx solid #DFE6E9;
  font-size: 24rpx; color: #636E72; font-weight: 500;
}
.cat-pill.active {
  background: #E94560; border-color: #E94560; color: #fff;
}

/* 提示 */
.hint { text-align: center; padding: 8rpx 0 12rpx; }
.hint-text { font-size: 22rpx; color: #636E72; }

/* 菜谱网格 */
.recipe-grid {
  display: grid; grid-template-columns: repeat(2, 1fr); gap: 14rpx;
  padding: 0 24rpx;
}
.recipe-card {
  background: #fff; border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04), 0 8rpx 20rpx rgba(0,0,0,0.06);
}
.recipe-card:active { transform: scale(0.97); }
.card-media {
  position: relative; width: 100%; height: 200rpx;
  background: #F8F9FA; display: flex; align-items: center; justify-content: center;
}
.card-img { width: 120rpx; height: 120rpx; }
.card-badge {
  position: absolute; top: 10rpx; right: 10rpx;
  background: #4ECDC4; color: #fff; font-size: 20rpx;
  padding: 4rpx 14rpx; border-radius: 100rpx; font-weight: 500;
}
.card-body { padding: 14rpx 18rpx 18rpx; }
.card-name {
  font-size: 28rpx; font-weight: 600; color: #2D3436; display: block;
  margin-bottom: 4rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.card-meta { font-size: 22rpx; color: #636E72; display: block; }

/* 骨架屏 */
.skel-img { width: 100%; height: 200rpx; }
.skel-line { height: 24rpx; margin: 12rpx 16rpx 0; }
.skel-line.sm { width: 55%; margin-bottom: 16rpx; }
