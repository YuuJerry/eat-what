<!-- 菜谱详情 — 杂志菜谱风格 -->
<view class="page" wx:if="{{recipe}}">

  <!-- ===== 自定义导航栏 ===== -->
  <view class="nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-inner">
      <view class="nav-back" bindtap="onBack">
        <view class="back-arrow"></view>
      </view>
    </view>
  </view>

  <!-- ===== 大标题头 ===== -->
  <view class="hero" style="padding-top: {{statusBarHeight + 44}}px;">
    <text class="hero-name">{{recipe.name}}</text>
    <view class="hero-line"></view>
    <view class="hero-stats">
      <view class="stat">
        <text class="stat-num">{{recipe.cookTime}}</text>
        <text class="stat-label">分钟</text>
      </view>
      <view class="stat-sep"></view>
      <view class="stat">
        <text class="stat-num">{{recipe.calories}}</text>
        <text class="stat-label">千卡</text>
      </view>
      <view class="stat-sep"></view>
      <view class="stat">
        <text class="stat-num">{{recipe.servings}}</text>
        <text class="stat-label">人份</text>
      </view>
    </view>
  </view>

  <!-- ===== 产品图白卡 ===== -->
  <view class="img-card">
    <image src="{{recipe.coverIcon}}" mode="aspectFit" class="main-img" />
    <view class="img-badge" wx:if="{{recipe.isDietFriendly}}">轻食</view>
  </view>

  <!-- ===== 标签行 ===== -->
  <view class="tag-bar" wx:if="{{recipe.isDietFriendly || (recipe.tags && recipe.tags.length > 0)}}">
    <text class="pill pill--green" wx:if="{{recipe.isDietFriendly}}">减脂</text>
    <text class="pill" wx:for="{{recipe.tags}}" wx:key="*this">{{item}}</text>
  </view>

  <!-- ===== 深色视频带 ===== -->
  <view class="dark-band" wx:if="{{recipe.videos && recipe.videos.length > 0}}">
    <text class="band-title">视频教程</text>
    <view
      class="vid-card"
      wx:for="{{recipe.videos}}"
      wx:key="url"
      bindtap="onVideoTap"
      data-video="{{item}}"
    >
      <view class="vid-thumb">
        <image wx:if="{{item.cover}}" src="{{item.cover}}" mode="aspectFill" class="vid-img" />
        <view class="vid-play">
          <view class="play-triangle"></view>
        </view>
        <text class="vid-dur" wx:if="{{item.duration}}">{{item.duration}}</text>
      </view>
      <view class="vid-info">
        <text class="vid-title">{{item.title}}</text>
        <text class="vid-author">{{item.author}}</text>
        <text class="vid-meta">{{item.playText}}</text>
      </view>
    </view>
  </view>

  <!-- ===== 食材清单（可折叠） ===== -->
  <view class="section-card">
    <view class="section-head" bindtap="onToggleIngredients">
      <text class="section-title">食材清单</text>
      <view class="section-right">
        <text class="section-count">{{recipe.ingredients.length}}种</text>
        <view class="fold-arrow {{showIngredients ? 'open' : ''}}"></view>
      </view>
    </view>
    <view class="ing-grid" wx:if="{{showIngredients}}">
      <view
        class="ing-item"
        wx:for="{{recipe.ingredients}}"
        wx:key="name"
        bindtap="onCheckIngredient"
        data-name="{{item.name}}"
      >
        <view class="ing-check {{checkedMap[item.name] ? 'on' : ''}}">
          <view class="check-tick" wx:if="{{checkedMap[item.name]}}"></view>
        </view>
        <view class="ing-text">
          <text class="ing-name">{{item.name}}</text>
          <text class="ing-amt">{{item.amount}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 烹饪步骤 ===== -->
  <view class="section-card">
    <text class="section-title">烹饪步骤</text>
    <view class="step-list">
      <view class="step" wx:for="{{recipe.steps}}" wx:key="index">
        <view class="step-num">{{index + 1}}</view>
        <text class="step-txt">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- ===== 营养信息 ===== -->
  <view class="section-card" wx:if="{{recipe.nutritionInfo}}">
    <text class="section-title">营养信息（每份）</text>
    <view class="nutr-table">
      <view class="nutr-row">
        <text class="nutr-key">蛋白质</text>
        <text class="nutr-val">{{recipe.nutritionInfo.protein}}g</text>
      </view>
      <view class="nutr-row">
        <text class="nutr-key">脂肪</text>
        <text class="nutr-val">{{recipe.nutritionInfo.fat}}g</text>
      </view>
      <view class="nutr-row">
        <text class="nutr-key">碳水</text>
        <text class="nutr-val">{{recipe.nutritionInfo.carbs}}g</text>
      </view>
      <view class="nutr-row">
        <text class="nutr-key">纤维</text>
        <text class="nutr-val">{{recipe.nutritionInfo.fiber}}g</text>
      </view>
    </view>
  </view>

  <!-- ===== 免责声明 ===== -->
  <view class="disclaimer">
    <text>菜谱仅供参考，请根据实际情况调整</text>
  </view>

  <!-- 底部占位 -->
  <view class="bar-placeholder"></view>

  <!-- ===== 固定底部操作栏 ===== -->
  <view class="action-bar">
    <view class="action-btn" bindtap="onToggleFavorite">
      <view class="action-icon {{isFavorited ? 'fav-on' : ''}}">
        <view class="heart {{isFavorited ? 'heart-on' : ''}}"></view>
      </view>
      <text class="action-label">{{isFavorited ? '已收藏' : '收藏'}}</text>
    </view>
    <button class="action-btn action-btn--share" open-type="share">
      <view class="action-icon">
        <view class="share-arrow"></view>
      </view>
      <text class="action-label">分享</text>
    </button>
  </view>
</view>

<!-- ===== 加载态 ===== -->
<view class="loading" wx:if="{{isLoading}}">
  <view class="loading-spinner"></view>
  <text class="loading-txt">加载中...</text>
</view>

<!-- ===== 空态 ===== -->
<view class="empty" wx:if="{{!isLoading && !recipe}}">
  <text class="empty-txt">未找到菜谱</text>
</view>
