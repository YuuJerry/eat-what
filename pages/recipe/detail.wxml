<!-- 菜谱详情 — 杂志菜谱风格 -->
<view class="page" wx:if="{{recipe}}">

  <!-- ===== 大标题头 ===== -->
  <view class="detail-hero">
    <view class="hero-status-bar" style="height: {{statusBarHeight}}px;"></view>
    <view class="hero-back" bindtap="onBack">
      <text>← 返回</text>
    </view>
    <text class="hero-name">{{recipe.name}}</text>
    <view class="hero-line"></view>
    <view class="hero-stats">
      <view class="stat">
        <text class="stat-num">{{recipe.cookTime}}</text>
        <text class="stat-label">分钟</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat">
        <text class="stat-num">{{recipe.calories}}</text>
        <text class="stat-label">千卡</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat">
        <text class="stat-num">{{recipe.servings}}</text>
        <text class="stat-label">人份</text>
      </view>
    </view>
  </view>

  <!-- ===== 产品图 ===== -->
  <view class="detail-img">
    <image src="{{recipe.coverIcon}}" mode="aspectFit" class="main-img" />
    <view class="img-badge" wx:if="{{recipe.isDietFriendly}}">轻食</view>
  </view>

  <!-- ===== 标签 ===== -->
  <view class="tag-bar" wx:if="{{recipe.tags && recipe.tags.length > 0}}">
    <text class="pill {{recipe.isDietFriendly ? 'pill-green' : ''}}" wx:if="{{recipe.isDietFriendly}}">减脂</text>
    <text class="pill" wx:for="{{recipe.tags}}" wx:key="*this">{{item}}</text>
  </view>

  <!-- ===== 视频教程 ===== -->
  <view class="dark-band" wx:if="{{recipe.videos && recipe.videos.length > 0}}">
    <text class="band-heading">🎬 视频教程</text>
    <view
      class="vid-card"
      wx:for="{{recipe.videos}}"
      wx:key="url"
      bindtap="onVideoTap"
      data-video="{{item}}"
    >
      <view class="vid-thumb">
        <image wx:if="{{item.cover}}" src="{{item.cover}}" mode="aspectFill" class="vid-img" />
        <view class="vid-play"><text>▶</text></view>
        <text class="vid-dur" wx:if="{{item.duration}}">{{item.duration}}</text>
      </view>
      <view class="vid-info">
        <text class="vid-title">{{item.title}}</text>
        <text class="vid-sub">{{item.author}} · {{item.playText}}</text>
        <text class="vid-cta">点击观看 →</text>
      </view>
    </view>
  </view>

  <!-- ===== 食材清单（可折叠） ===== -->
  <view class="white-card">
    <view class="card-head" bindtap="onToggleIngredients">
      <text class="card-heading">食材清单</text>
      <text class="card-count">{{recipe.ingredients.length}}种</text>
      <text class="card-arrow">{{showIngredients ? '▲' : '▼'}}</text>
    </view>
    <view wx:if="{{showIngredients}}" class="ing-grid">
      <view
        class="ing-chip"
        wx:for="{{recipe.ingredients}}"
        wx:key="name"
        bindtap="onCheckIngredient"
        data-name="{{item.name}}"
      >
        <view class="ing-check {{checkedIngredients.includes(item.name) ? 'on' : ''}}">
          <text wx:if="{{checkedIngredients.includes(item.name)}}">✓</text>
        </view>
        <view class="ing-text">
          <text class="ing-name">{{item.name}}</text>
          <text class="ing-amt">{{item.amount}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 烹饪步骤 ===== -->
  <view class="white-card">
    <text class="card-heading">烹饪步骤</text>
    <view class="step-list">
      <view class="step" wx:for="{{recipe.steps}}" wx:key="index">
        <view class="step-num"><text>{{index + 1}}</text></view>
        <text class="step-txt">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- ===== 营养信息 ===== -->
  <view class="white-card" wx:if="{{recipe.nutritionInfo}}">
    <text class="card-heading">营养信息（每份）</text>
    <view class="nutr-table">
      <view class="nutr-row">
        <text class="nutr-key">蛋白质</text>
        <text class="nutr-val">{{recipe.nutritionInfo.protein}}g</text>
      </view>
      <view class="nutr-row">
        <text class="nutr-key">脂肪</text>
        <text class="nutr-val">{{recipe.nutritionInfo.fat}}g</text>
      </view>
      <view class="nutr-row">
        <text class="nutr-key">碳水</text>
        <text class="nutr-val">{{recipe.nutritionInfo.carbs}}g</text>
      </view>
      <view class="nutr-row">
        <text class="nutr-key">纤维</text>
        <text class="nutr-val">{{recipe.nutritionInfo.fiber}}g</text>
      </view>
    </view>
  </view>

  <!-- ===== 免责 ===== -->
  <view class="foot-note">
    <text>📋 菜谱仅供参考，请根据实际情况调整</text>
  </view>

  <!-- ===== 底部操作栏 ===== -->
  <view class="bar">
    <view class="bar-btn" bindtap="onToggleFavorite">
      <text class="bar-icon">{{isFavorited ? '❤️' : '🤍'}}</text>
      <text class="bar-txt">{{isFavorited ? '已收藏' : '收藏'}}</text>
    </view>
    <button class="bar-btn share" open-type="share">
      <text class="bar-icon">📤</text>
      <text class="bar-txt">分享</text>
    </button>
  </view>
</view>

<!-- 加载 -->
<view class="loading" wx:if="{{isLoading}}">
  <text class="loading-txt">加载中...</text>
</view>
