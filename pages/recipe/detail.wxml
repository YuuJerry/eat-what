<!-- 菜谱详情 — 星巴克产品详情风格 -->
<view class="page" wx:if="{{recipe}}">

  <!-- ===== 深绿产品头 ===== -->
  <view class="pdp-header">
    <view class="pdp-breadcrumb">
      <text class="bc-link" bindtap="onBack">菜谱</text>
      <text class="bc-sep">/</text>
      <text class="bc-current">{{recipe.name}}</text>
    </view>
    <text class="pdp-title">{{recipe.name}}</text>
    <view class="pdp-meta-row">
      <text class="pdp-meta">⏱ {{recipe.cookTime}}分钟</text>
      <text class="pdp-meta">👥 {{recipe.servings}}人份</text>
      <text class="pdp-meta" wx:if="{{recipe.calories}}">🔥 {{recipe.calories}}kcal</text>
    </view>
  </view>

  <!-- ===== 产品图 ===== -->
  <view class="pdp-image">
    <image src="{{recipe.coverIcon}}" mode="aspectFit" class="pdp-img" />
    <view class="pdp-diet" wx:if="{{recipe.isDietFriendly}}">轻食</view>
  </view>

  <!-- ===== 标签行 ===== -->
  <view class="tag-row" wx:if="{{recipe.tags && recipe.tags.length > 0}}">
    <text class="pill-tag {{recipe.isDietFriendly ? 'pill-green' : ''}}" wx:if="{{recipe.isDietFriendly}}">减脂</text>
    <text class="pill-tag" wx:for="{{recipe.tags}}" wx:key="*this">{{item}}</text>
  </view>

  <!-- ===== 视频教程 ===== -->
  <view class="band-dark" wx:if="{{recipe.videos && recipe.videos.length > 0}}">
    <text class="band-title">🎬 视频教程</text>
    <view
      class="video-row"
      wx:for="{{recipe.videos}}"
      wx:key="url"
      bindtap="onVideoTap"
      data-video="{{item}}"
    >
      <view class="video-thumb">
        <image wx:if="{{item.cover}}" src="{{item.cover}}" mode="aspectFill" class="thumb-img" />
        <view class="thumb-play"><text>▶</text></view>
        <text class="thumb-dur" wx:if="{{item.duration}}">{{item.duration}}</text>
      </view>
      <view class="video-meta">
        <text class="video-title">{{item.title}}</text>
        <text class="video-sub">{{item.author}} · {{item.playText}}</text>
        <text class="video-cta">点击观看 →</text>
      </view>
    </view>
  </view>

  <!-- ===== 食材清单 ===== -->
  <view class="section-card">
    <view class="card-header" bindtap="onToggleIngredients">
      <text class="card-title">📦 食材清单</text>
      <text class="card-count">{{recipe.ingredients.length}}种</text>
      <text class="card-arrow">{{showIngredients ? '▲' : '▼'}}</text>
    </view>
    <view wx:if="{{showIngredients}}" class="ingredient-grid">
      <view
        class="ingredient-chip"
        wx:for="{{recipe.ingredients}}"
        wx:key="name"
        bindtap="onCheckIngredient"
        data-name="{{item.name}}"
      >
        <view class="chip-check {{checkedIngredients.includes(item.name) ? 'checked' : ''}}">
          <text wx:if="{{checkedIngredients.includes(item.name)}}">✓</text>
        </view>
        <text class="chip-name">{{item.name}}</text>
        <text class="chip-amount">{{item.amount}}</text>
      </view>
    </view>
  </view>

  <!-- ===== 烹饪步骤 ===== -->
  <view class="section-card">
    <text class="card-title">👨‍🍳 烹饪步骤</text>
    <view class="steps-list">
      <view class="step-row" wx:for="{{recipe.steps}}" wx:key="index">
        <view class="step-num"><text>{{index + 1}}</text></view>
        <text class="step-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- ===== 营养信息 ===== -->
  <view class="section-card" wx:if="{{recipe.nutritionInfo}}">
    <text class="card-title">📊 营养信息（每份）</text>
    <view class="nutrition-table">
      <view class="nutr-row">
        <text class="nutr-label">蛋白质</text>
        <text class="nutr-value">{{recipe.nutritionInfo.protein}}g</text>
      </view>
      <view class="nutr-row">
        <text class="nutr-label">脂肪</text>
        <text class="nutr-value">{{recipe.nutritionInfo.fat}}g</text>
      </view>
      <view class="nutr-row">
        <text class="nutr-label">碳水</text>
        <text class="nutr-value">{{recipe.nutritionInfo.carbs}}g</text>
      </view>
      <view class="nutr-row">
        <text class="nutr-label">纤维</text>
        <text class="nutr-value">{{recipe.nutritionInfo.fiber}}g</text>
      </view>
    </view>
  </view>

  <!-- ===== 免责声明 ===== -->
  <view class="disclaimer">
    <text>📋 菜谱仅供参考，请根据实际情况调整</text>
  </view>

  <!-- ===== 底部浮动操作栏 ===== -->
  <view class="bottom-bar">
    <view class="bar-btn bar-fav" bindtap="onToggleFavorite">
      <text>{{isFavorited ? '❤️' : '🤍'}}</text>
      <text class="bar-label">{{isFavorited ? '已收藏' : '收藏'}}</text>
    </view>
    <button class="bar-btn bar-share" open-type="share">
      <text>📤</text>
      <text class="bar-label">分享</text>
    </button>
  </view>
</view>

<!-- 加载状态 -->
<view class="loading-state" wx:if="{{isLoading}}">
  <text class="loading-text">加载中...</text>
</view>
