<!-- 菜谱列表 -->
<view class="page">
  <!-- 搜索条 -->
  <view class="search-section">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索菜谱或食材" value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch" confirm-type="search" />
      <view class="search-go" wx:if="{{keyword}}" bindtap="onSearch"><text>搜索</text></view>
    </view>
  </view>

  <!-- 分类标签 -->
  <scroll-view scroll-x class="cat-scroll" enable-flex>
    <view class="cat-pill {{activeCategory === item ? 'active' : ''}}" wx:for="{{categories}}" wx:key="*this" bindtap="onCategoryChange" data-cat="{{item}}">
      <text>{{item}}</text>
    </view>
  </scroll-view>

  <!-- 提示 -->
  <view class="hint" wx:if="{{recipes.length > 0}}">
    <text class="hint-text">下拉刷新换一批</text>
  </view>

  <!-- 菜谱网格 -->
  <view class="recipe-grid" wx:if="{{!isLoading && recipes.length > 0}}">
    <view class="recipe-card" wx:for="{{recipes}}" wx:key="name" bindtap="onRecipeTap" data-index="{{index}}">
      <view class="card-media">
        <image src="{{item.coverIcon}}" mode="aspectFit" class="card-img" />
        <view class="card-badge" wx:if="{{item.isDietFriendly}}">轻食</view>
      </view>
      <view class="card-body">
        <text class="card-name">{{item.name}}</text>
        <text class="card-meta">{{item.cookTime}}分 · {{item.calories}}kcal</text>
      </view>
    </view>
  </view>

  <!-- 骨架屏 -->
  <view class="recipe-grid" wx:if="{{isLoading}}">
    <view class="recipe-card" wx:for="{{[1,2,3,4]}}" wx:key="*this">
      <view class="card-media"><view class="skeleton skel-img"></view></view>
      <view class="card-body"><view class="skeleton skel-line"></view><view class="skeleton skel-line sm"></view></view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!isLoading && recipes.length === 0}}">
    <text class="empty-emoji">🍽️</text>
    <text class="empty-text">暂无菜谱</text>
  </view>
</view>
