<!-- 菜谱列表页 -->
<view class="page">

  <!-- 搜索条 -->
  <view class="search-bar">
    <view class="search-icon-wrap">
      <view class="search-icon-circle">
        <view class="search-icon-glass"></view>
        <view class="search-icon-handle"></view>
      </view>
    </view>
    <input
      class="search-input"
      placeholder="搜索菜谱或食材"
      placeholder-class="search-placeholder"
      value="{{keyword}}"
      bindinput="onSearchInput"
      bindconfirm="onSearch"
      confirm-type="search"
    />
    <view class="search-go" wx:if="{{keyword}}" bindtap="onSearch">
      <text>搜索</text>
    </view>
  </view>

  <!-- 分类标签 -->
  <scroll-view scroll-x class="cat-scroll" enhanced show-scrollbar="{{false}}">
    <view
      class="cat-pill {{activeCategory === item ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="*this"
      bindtap="onCategoryChange"
      data-cat="{{item}}"
    >
      <text>{{item}}</text>
    </view>
  </scroll-view>

  <!-- 提示 -->
  <view class="hint" wx:if="{{!isLoading && recipes.length > 0}}">
    <text class="hint-text">下拉刷新换一批</text>
  </view>

  <!-- 菜谱网格 -->
  <view class="recipe-grid" wx:if="{{!isLoading && recipes.length > 0}}">
    <view
      class="recipe-card"
      wx:for="{{recipes}}"
      wx:key="name"
      bindtap="onRecipeTap"
      data-index="{{index}}"
    >
      <view class="card-media">
        <image src="{{item.coverIcon}}" mode="aspectFit" class="card-img" />
        <view class="card-badge" wx:if="{{item.isDietFriendly}}">轻食</view>
      </view>
      <view class="card-body">
        <text class="card-name">{{item.name}}</text>
        <text class="card-meta">{{item.cookTime}}min · {{item.calories}}kcal</text>
      </view>
    </view>
  </view>

  <!-- 骨架屏 -->
  <view class="recipe-grid" wx:if="{{isLoading}}">
    <view class="recipe-card skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="*this">
      <view class="card-media">
        <view class="skeleton skel-img"></view>
      </view>
      <view class="card-body">
        <view class="skeleton skel-line"></view>
        <view class="skeleton skel-line short"></view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!isLoading && recipes.length === 0}}">
    <view class="empty-icon">
      <view class="empty-bowl"></view>
      <view class="empty-steam"></view>
    </view>
    <text class="empty-text">暂无菜谱</text>
    <text class="empty-sub">换个分类试试吧</text>
  </view>

</view>
