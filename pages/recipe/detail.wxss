/* 菜谱详情 — 杂志菜谱风格 */
/* 深咖头 · 大标题 · 赤陶装饰 · 暖白卡 */

.page {
  background: #FAF6F1;
  padding-bottom: 140rpx;
}

/* ===== 大标题头 ===== */
.detail-hero {
  background: #2D2A26;
  padding: 32rpx 32rpx 36rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.hero-status-bar {
  width: 100%;
}

.hero-back {
  margin-bottom: 16rpx;
}

.hero-back text {
  font-size: 24rpx;
  color: rgba(250, 246, 241, 0.55);
}

.hero-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #FAF6F1;
  display: block;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.hero-line {
  width: 56rpx;
  height: 4rpx;
  background: #C85A36;
  border-radius: 2rpx;
  margin-bottom: 20rpx;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #FAF6F1;
  display: block;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(250, 246, 241, 0.45);
  margin-top: 2rpx;
  display: block;
}

.stat-divider {
  width: 2rpx;
  height: 36rpx;
  background: rgba(250, 246, 241, 0.15);
}

/* ===== 产品图 ===== */
.detail-img {
  position: relative;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  margin: 16rpx 24rpx;
  border-radius: 24rpx;
  box-shadow:
    0 2rpx 8rpx rgba(139, 120, 90, 0.06),
    0 8rpx 24rpx rgba(139, 120, 90, 0.08);
}

.main-img {
  width: 220rpx;
  height: 220rpx;
}

.img-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: #6B8F71;
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  font-weight: 500;
}

/* ===== 标签行 ===== */
.tag-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 24rpx 16rpx;
}

.pill {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  background: rgba(200, 90, 54, 0.08);
  color: #C85A36;
  font-weight: 500;
}

.pill-green {
  background: rgba(107, 143, 113, 0.12);
  color: #6B8F71;
}

/* ===== 深色视频带 ===== */
.dark-band {
  background: #2D2A26;
  padding: 28rpx 24rpx;
  margin: 0 0 16rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.band-heading {
  font-size: 28rpx;
  font-weight: 600;
  color: #FAF6F1;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.vid-card {
  display: flex;
  gap: 16rpx;
  background: rgba(250, 246, 241, 0.06);
  border: 1rpx solid rgba(250, 246, 241, 0.08);
  border-radius: 16rpx;
  padding: 14rpx;
  margin-bottom: 12rpx;
}

.vid-card:active {
  background: rgba(250, 246, 241, 0.10);
}

.vid-thumb {
  position: relative;
  width: 180rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.vid-img {
  width: 100%;
  height: 100%;
}

.vid-play {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 44rpx;
  height: 44rpx;
  background: rgba(200, 90, 54, 0.85);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
}

.vid-dur {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  background: rgba(0, 0, 0, 0.65);
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.vid-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.vid-title {
  font-size: 24rpx;
  color: #FAF6F1;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 4rpx;
}

.vid-sub {
  font-size: 20rpx;
  color: rgba(250, 246, 241, 0.45);
  margin-bottom: 6rpx;
}

.vid-cta {
  font-size: 22rpx;
  color: #C85A36;
  font-weight: 500;
}

/* ===== 白卡内容 ===== */
.white-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 0 24rpx 16rpx;
  box-shadow:
    0 2rpx 8rpx rgba(139, 120, 90, 0.06),
    0 8rpx 24rpx rgba(139, 120, 90, 0.08);
}

.card-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-heading {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D2A26;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.card-head .card-heading {
  margin-bottom: 0;
  flex: 1;
}

.card-count {
  font-size: 24rpx;
  color: #8A8279;
}

.card-arrow {
  font-size: 22rpx;
  color: #8A8279;
  padding: 8rpx;
}

/* 食材网格 */
.ing-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.ing-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 14rpx;
  background: #FAF6F1;
  border-radius: 14rpx;
}

.ing-check {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 2rpx solid #D4C4B0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: transparent;
  flex-shrink: 0;
}

.ing-check.on {
  background: #C85A36;
  border-color: #C85A36;
  color: #fff;
}

.ing-text {
  flex: 1;
  min-width: 0;
}

.ing-name {
  font-size: 24rpx;
  color: #2D2A26;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ing-amt {
  font-size: 20rpx;
  color: #8A8279;
  display: block;
}

/* 步骤列表 */
.step-list {
  margin-top: 16rpx;
}

.step {
  display: flex;
  gap: 14rpx;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.step-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #C85A36;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.step-txt {
  font-size: 26rpx;
  color: rgba(45, 42, 38, 0.87);
  line-height: 1.7;
  flex: 1;
  padding-top: 2rpx;
}

/* 营养表格 */
.nutr-table {
  margin-top: 16rpx;
}

.nutr-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F0E8DE;
}

.nutr-row:last-child {
  border-bottom: none;
}

.nutr-key {
  font-size: 26rpx;
  color: #8A8279;
}

.nutr-val {
  font-size: 26rpx;
  font-weight: 600;
  color: #2D2A26;
}

/* 免责 */
.foot-note {
  text-align: center;
  padding: 24rpx 32rpx 32rpx;
  font-size: 22rpx;
  color: #8A8279;
}

/* ===== 底部操作栏 ===== */
.bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 64rpx;
  box-shadow:
    0 -2rpx 8rpx rgba(139, 120, 90, 0.06),
    0 -8rpx 24rpx rgba(139, 120, 90, 0.08);
  z-index: 100;
}

.bar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.bar-btn:active {
  transform: scale(0.95);
}

.bar-icon {
  font-size: 36rpx;
}

.bar-txt {
  font-size: 20rpx;
  color: #8A8279;
}

.bar-btn.share {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  font-size: inherit;
  color: inherit;
  text-align: center;
  box-sizing: content-box;
}

.bar-btn.share::after {
  border: none;
}

/* 加载 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-txt {
  font-size: 28rpx;
  color: #8A8279;
}
