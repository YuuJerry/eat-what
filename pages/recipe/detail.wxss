/* 菜谱详情 — 杂志菜谱风格 */
/* 深咖头 · 大标题 · 赤陶装饰 · 暖白卡 */

/* ===== 全局 ===== */
.page {
  background: #FAF6F1;
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 自定义导航栏 ===== */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 200;
  background: #2D2A26;
}

.nav-inner {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 12px;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid rgba(250, 246, 241, 0.7);
  border-bottom: 4rpx solid rgba(250, 246, 241, 0.7);
  transform: rotate(45deg);
}

/* ===== 大标题头 ===== */
.hero {
  background: #2D2A26;
  padding-left: 40rpx;
  padding-right: 40rpx;
  padding-bottom: 40rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.hero-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #FAF6F1;
  display: block;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.hero-line {
  width: 56rpx;
  height: 5rpx;
  background: #C85A36;
  border-radius: 3rpx;
  margin-bottom: 24rpx;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 34rpx;
  font-weight: 700;
  color: #FAF6F1;
  display: block;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(250, 246, 241, 0.4);
  margin-top: 2rpx;
  display: block;
}

.stat-sep {
  width: 2rpx;
  height: 36rpx;
  background: rgba(250, 246, 241, 0.12);
}

/* ===== 产品图白卡 ===== */
.img-card {
  position: relative;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0;
  margin: 16rpx 24rpx 0;
  border-radius: 24rpx;
  box-shadow:
    0 2rpx 8rpx rgba(139, 120, 90, 0.06),
    0 8rpx 24rpx rgba(139, 120, 90, 0.08);
}

.main-img {
  width: 220rpx;
  height: 220rpx;
}

.img-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: #6B8F71;
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  font-weight: 600;
}

/* ===== 标签行 ===== */
.tag-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 16rpx 24rpx 0;
}

.pill {
  font-size: 22rpx;
  padding: 8rpx 22rpx;
  border-radius: 100rpx;
  background: rgba(200, 90, 54, 0.1);
  color: #C85A36;
  font-weight: 500;
}

.pill--green {
  background: rgba(107, 143, 113, 0.12);
  color: #6B8F71;
}

/* ===== 深色视频带 ===== */
.dark-band {
  background: #2D2A26;
  padding: 28rpx 24rpx 32rpx;
  margin-top: 16rpx;
  border-radius: 0 0 32rpx 32rpx;
}

.band-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FAF6F1;
  display: block;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.vid-card {
  display: flex;
  gap: 18rpx;
  background: rgba(250, 246, 241, 0.06);
  border: 1rpx solid rgba(250, 246, 241, 0.08);
  border-radius: 16rpx;
  padding: 14rpx;
  margin-bottom: 14rpx;
}

.vid-card:active {
  background: rgba(250, 246, 241, 0.1);
}

.vid-thumb {
  position: relative;
  width: 180rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: rgba(250, 246, 241, 0.08);
}

.vid-img {
  width: 100%;
  height: 100%;
}

.vid-play {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 48rpx;
  height: 48rpx;
  background: rgba(200, 90, 54, 0.85);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-triangle {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 16rpx solid #fff;
  margin-left: 4rpx;
}

.vid-dur {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  background: rgba(0, 0, 0, 0.65);
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.vid-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.vid-title {
  font-size: 24rpx;
  color: #FAF6F1;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 6rpx;
}

.vid-author {
  font-size: 20rpx;
  color: rgba(250, 246, 241, 0.5);
  margin-bottom: 4rpx;
}

.vid-meta {
  font-size: 20rpx;
  color: #C85A36;
}

/* ===== 内容白卡（通用） ===== */
.section-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 16rpx 24rpx 0;
  box-shadow:
    0 2rpx 8rpx rgba(139, 120, 90, 0.06),
    0 8rpx 24rpx rgba(139, 120, 90, 0.08);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D2A26;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.section-head .section-title {
  margin-bottom: 0;
}

.section-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-count {
  font-size: 24rpx;
  color: #8A8279;
}

.fold-arrow {
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid #8A8279;
  border-bottom: 3rpx solid #8A8279;
  transform: rotate(45deg);
  transition: transform 0.2s;
}

.fold-arrow.open {
  transform: rotate(-135deg);
}

/* ===== 食材网格 ===== */
.ing-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.ing-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 16rpx;
  background: #FAF6F1;
  border-radius: 14rpx;
}

.ing-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #D4C4B0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.ing-check.on {
  background: #C85A36;
  border-color: #C85A36;
}

.check-tick {
  width: 14rpx;
  height: 8rpx;
  border-left: 3rpx solid #fff;
  border-bottom: 3rpx solid #fff;
  transform: rotate(-45deg);
  margin-top: -2rpx;
}

.ing-text {
  flex: 1;
  min-width: 0;
}

.ing-name {
  font-size: 24rpx;
  color: #2D2A26;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ing-amt {
  font-size: 20rpx;
  color: #8A8279;
  display: block;
  margin-top: 2rpx;
}

/* ===== 烹饪步骤 ===== */
.step-list {
  margin-top: 20rpx;
}

.step {
  display: flex;
  gap: 16rpx;
  margin-bottom: 22rpx;
  align-items: flex-start;
}

.step:last-child {
  margin-bottom: 0;
}

.step-num {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #C85A36;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.step-txt {
  font-size: 26rpx;
  color: rgba(45, 42, 38, 0.87);
  line-height: 1.7;
  flex: 1;
  padding-top: 4rpx;
}

/* ===== 营养表格 ===== */
.nutr-table {
  margin-top: 16rpx;
}

.nutr-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0E8DE;
}

.nutr-row:last-child {
  border-bottom: none;
}

.nutr-key {
  font-size: 26rpx;
  color: #8A8279;
}

.nutr-val {
  font-size: 26rpx;
  font-weight: 600;
  color: #2D2A26;
}

/* ===== 免责声明 ===== */
.disclaimer {
  text-align: center;
  padding: 28rpx 40rpx 16rpx;
  font-size: 22rpx;
  color: #B0A89E;
}

/* ===== 底部操作栏 ===== */
.bar-placeholder {
  height: 130rpx;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow:
    0 -2rpx 8rpx rgba(139, 120, 90, 0.06),
    0 -8rpx 24rpx rgba(139, 120, 90, 0.08);
  z-index: 100;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
  font-size: inherit;
  color: inherit;
}

.action-btn::after {
  border: none;
}

.action-btn:active {
  transform: scale(0.92);
}

.action-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-label {
  font-size: 20rpx;
  color: #8A8279;
}

/* 心形图标 */
.heart {
  width: 36rpx;
  height: 32rpx;
  position: relative;
}

.heart::before,
.heart::after {
  content: '';
  position: absolute;
  top: 0;
  width: 20rpx;
  height: 32rpx;
  border-radius: 20rpx 20rpx 0 0;
  background: #B0A89E;
}

.heart::before {
  left: 0;
  transform: rotate(-45deg);
  transform-origin: bottom right;
}

.heart::after {
  right: 0;
  transform: rotate(45deg);
  transform-origin: bottom left;
}

.heart-on::before,
.heart-on::after {
  background: #C85A36;
}

/* 分享图标 */
.share-arrow {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #8A8279;
  border-radius: 4rpx;
  position: relative;
}

.share-arrow::after {
  content: '';
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  border-right: 3rpx solid #8A8279;
  border-bottom: 3rpx solid #8A8279;
}

/* ===== 加载态 ===== */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: 16rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #F0E8DE;
  border-top-color: #C85A36;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-txt {
  font-size: 26rpx;
  color: #8A8279;
}

/* ===== 空态 ===== */
.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.empty-txt {
  font-size: 28rpx;
  color: #B0A89E;
}
