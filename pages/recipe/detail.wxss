/* 页面容器：底部留出底部操作栏的高度 */
.container {
  padding-bottom: 140rpx;
}

/* ===== 加载状态样式 ===== */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

/* 加载文字 */
.loading-text {
  color: #999;
  font-size: 28rpx;
}

/* ===== 封面样式 ===== */
.cover {
  width: 100%;
  height: 400rpx;
}

/* 封面 emoji 大图标 */
.cover-emoji {
  font-size: 100rpx;
}

/* 封面手绘图标 */
.cover-icon-img {
  width: 200rpx;
  height: 200rpx;
}

/* ===== 信息卡片样式 ===== */
/* 信息卡片：上移覆盖封面，营造层叠效果 */
.info-card {
  margin-top: -40rpx;
  position: relative;
  z-index: 1;
}

/* 菜谱标题 */
.recipe-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

/* 元信息行：横向排列各属性徽章 */
.recipe-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

/* 单个属性徽章 */
.meta-badge {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

/* 热量徽章：橙色高亮 */
.meta-badge.calorie {
  background: #FFF0E5;
  color: #FF8C00;
}

/* 标签容器 */
.recipe-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

/* ===== 食材清单样式 ===== */
.ingredient-list {
  margin-top: 16rpx;
}

.ingredient-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

/* 食材勾选圆圈：未选中为空心，选中为绿色实心 */
.ingredient-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 24rpx;
  color: #fff;
}

/* 食材勾选状态：绿色背景 */
.ingredient-check.checked {
  background: #4ECDC4;
  border-color: #4ECDC4;
}

/* 食材图标占位 */
.ingredient-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 食材图标文字大小 */
.ingredient-icon text {
  font-size: 30rpx;
}

/* 食材手绘图标 */
.ingredient-img {
  width: 48rpx;
  height: 48rpx;
}

/* 食材信息行：名称和用量左右分布 */
.ingredient-info {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 食材名称 */
.ingredient-name {
  font-size: 28rpx;
  color: #333;
}

/* 食材用量 */
.ingredient-amount {
  font-size: 24rpx;
  color: #999;
}

/* 食材拥有情况汇总条 */
.ingredient-summary {
  margin-top: 16rpx;
  padding: 12rpx 20rpx;
  background: #E8F8F5;
  border-radius: 12rpx;
}

/* 汇总文字 */
.summary-text {
  font-size: 26rpx;
  color: #4ECDC4;
}

/* ===== 烹饪步骤样式 ===== */
.step-list {
  margin-top: 16rpx;
}

.step-item {
  display: flex;
  margin-bottom: 24rpx;
}

/* 步骤序号圆圈：红色圆形带白色数字 */
.step-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #FF6B6B;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
  margin-right: 16rpx;
}

/* 步骤内容区域 */
.step-content {
  flex: 1;
}

/* 步骤文字描述 */
.step-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 步骤配图容器 */
.step-img {
  width: 100%;
  height: 200rpx;
  margin-top: 12rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

/* 步骤配图填满容器 */
.step-img image {
  width: 100%;
  height: 100%;
}

/* ===== 营养信息样式 ===== */
.nutrition-grid {
  display: flex;
  justify-content: space-around;
  margin-top: 16rpx;
}

/* 营养项：垂直居中排列 */
.nutrition-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 营养数值：红色大字 */
.nutrition-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF6B6B;
}

/* 营养标签文字 */
.nutrition-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* ===== 视频教程样式 ===== */
.video-list {
  margin-top: 16rpx;
}

/* 单个视频项：横向布局，灰色背景卡片 */
.video-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

/* 视频封面占位：深色背景带播放图标 */
.video-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: #333;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

/* 视频信息区域 */
.video-info {
  flex: 1;
}

/* 视频标题 */
.video-title {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

/* 视频作者 */
.video-author {
  font-size: 24rpx;
  color: #999;
}

/* ===== 底部操作栏样式 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 底部按钮：垂直排列图标和文字 */
.bottom-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 36rpx;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

/* 分享按钮：去掉微信默认边框 */
.share-btn::after {
  border: none;
}

/* 按钮下方文字标签 */
.btn-label {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

/* ===== 通用区块样式 ===== */
.section {
  margin-bottom: 20rpx;
}

/* 区块标题：加粗大字 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

/* AI 免责声明 */
.ai-disclaimer {
  text-align: center;
  padding: 24rpx 0 120rpx;
}

.ai-disclaimer-text {
  font-size: 22rpx;
  color: #ccc;
}

/* 加载状态 */
.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}
