/* 菜谱详情 — 星巴克产品详情风格 */
/* 深绿头 → 产品图 → 标签 → 暗色视频带 → 白卡内容 */

.page {
  background: #f2f0eb;
  padding-bottom: 140rpx;
}

/* ===== 深绿产品头 ===== */
.pdp-header {
  background: #1E3932;
  padding: 32rpx 32rpx 40rpx;
}

.pdp-breadcrumb {
  margin-bottom: 16rpx;
}

.bc-link {
  font-size: 24rpx;
  color: #00754A;
  font-weight: 500;
}

.bc-sep {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.30);
  margin: 0 8rpx;
}

.bc-current {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.58);
}

.pdp-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
  letter-spacing: -0.16px;
  margin-bottom: 12rpx;
}

.pdp-meta-row {
  display: flex;
  gap: 24rpx;
}

.pdp-meta {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.70);
}

/* ===== 产品图 ===== */
.pdp-image {
  position: relative;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  margin-bottom: 4rpx;
}

.pdp-img {
  width: 240rpx;
  height: 240rpx;
}

.pdp-diet {
  position: absolute;
  top: 16rpx;
  right: 24rpx;
  background: #00754A;
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  font-weight: 500;
}

/* ===== 标签行 ===== */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 20rpx 32rpx;
  background: #ffffff;
  margin-bottom: 16rpx;
}

.pill-tag {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  background: #f2f0eb;
  color: rgba(0, 0, 0, 0.58);
  font-weight: 500;
}

.pill-green {
  background: #d4e9e2;
  color: #006241;
}

/* ===== 深色视频带（星巴克签名设计） ===== */
.band-dark {
  background: #1E3932;
  padding: 32rpx;
  margin-bottom: 16rpx;
}

.band-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
  margin-bottom: 20rpx;
}

.video-row {
  display: flex;
  gap: 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.video-row:active {
  background: rgba(255, 255, 255, 0.12);
}

.video-thumb {
  position: relative;
  width: 180rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.thumb-img {
  width: 100%;
  height: 100%;
}

.thumb-play {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.50);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
}

.thumb-dur {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  background: rgba(0, 0, 0, 0.70);
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.video-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.video-title {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 4rpx;
}

.video-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.58);
  margin-bottom: 6rpx;
}

.video-cta {
  font-size: 22rpx;
  color: #00754A;
  font-weight: 500;
}

/* ===== 白卡内容区块 ===== */
.section-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 28rpx;
  margin: 0 24rpx 16rpx;
  box-shadow:
    0 0 4rpx rgba(0, 0, 0, 0.14),
    0 2rpx 4rpx rgba(0, 0, 0, 0.24);
}

.card-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #006241;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: -0.16px;
}

.card-header .card-title {
  margin-bottom: 0;
  flex: 1;
}

.card-count {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.58);
}

.card-arrow {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.38);
  padding: 8rpx;
}

/* 食材网格 */
.ingredient-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
}

.ingredient-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 16rpx;
  background: #f2f0eb;
  border-radius: 16rpx;
}

.chip-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #d6dbde;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: transparent;
  flex-shrink: 0;
}

.chip-check.checked {
  background: #00754A;
  border-color: #00754A;
  color: #fff;
}

.chip-name {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.87);
  flex: 1;
}

.chip-amount {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.58);
}

/* 步骤列表 */
.steps-list {
  margin-top: 16rpx;
}

.step-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.step-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #00754A;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.step-text {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.87);
  line-height: 1.7;
  flex: 1;
  padding-top: 4rpx;
}

/* 营养信息表格 */
.nutrition-table {
  margin-top: 16rpx;
}

.nutr-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #edebe9;
}

.nutr-row:last-child {
  border-bottom: none;
}

.nutr-label {
  font-size: 26rpx;
  color: rgba(0, 0, 0, 0.58);
}

.nutr-value {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.87);
}

/* 免责声明 */
.disclaimer {
  text-align: center;
  padding: 24rpx 32rpx 32rpx;
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.38);
}

/* ===== 底部浮动操作栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow:
    0 -2rpx 4rpx rgba(0, 0, 0, 0.06),
    0 -8rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.bar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.bar-btn:active {
  transform: scale(0.95);
}

.bar-label {
  font-size: 20rpx;
  color: rgba(0, 0, 0, 0.58);
}

.bar-share {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

.loading-text {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.38);
}
