<!-- 投票大厅页面模板 - 包含快捷操作区、历史投票列表和空状态提示 -->
<view class="container">
  <!-- 快捷操作区：发起投票和加入投票两个入口卡片 -->
  <view class="action-cards">
    <!-- 发起投票卡片，点击跳转到创建投票页面 -->
    <view class="action-card create" bindtap="onCreateRoom">
      <text class="action-icon">🗳️</text>
      <text class="action-title">发起投票</text>
      <text class="action-desc">创建投票房间，邀请好友一起选</text>
    </view>
    <!-- 加入投票卡片，输入投票码 -->
    <view class="action-card join" bindtap="onJoinRoom">
      <text class="action-icon">🔗</text>
      <text class="action-title">加入投票</text>
      <text class="action-desc">输入好友发来的投票码</text>
    </view>
  </view>

  <!-- 历史投票列表：当用户有历史房间时显示 -->
  <view class="section" wx:if="{{myRooms.length > 0}}">
    <text class="section-title">📋 历史投票</text>
    <!-- 遍历历史房间列表，每个房间显示标题、房间码和状态 -->
    <view
      class="room-card card"
      wx:for="{{myRooms}}"
      wx:key="code"
      bindtap="onRoomTap"
      data-item="{{item}}"
    >
      <text class="room-title">{{item.title}}</text>
      <view class="room-meta">
        <text class="room-code">房间码: {{item.code}}</text>
        <!-- 根据房间状态显示"进行中"或"已结束"标签 -->
        <text class="room-status {{item.status === 'active' ? 'active' : ''}}">
          {{item.status === 'active' ? '进行中' : '已结束'}}
        </text>
      </view>
    </view>
  </view>

  <!-- 空状态：当用户没有历史投票记录时显示提示信息 -->
  <view class="empty-state" wx:if="{{myRooms.length === 0}}">
    <text class="empty-emoji">🗳️</text>
    <text class="empty-text">还没有投票记录</text>
    <text class="empty-hint">发起一个投票，和朋友一起决定吃什么吧！</text>
  </view>
</view>
