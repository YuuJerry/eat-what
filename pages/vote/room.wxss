/* 投票房间页面样式 */

/* 页面容器 */
.container {
  padding: 24rpx;
}

/* ===== 通用区域标题 ===== */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

/* ===== 创建投票模式 ===== */

/* 投票标题输入框 */
.title-input {
  font-size: 30rpx;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #eee;
}

/* 选项列表容器 */
.option-list {
  margin-bottom: 16rpx;
}

/* 单个选项行（输入框 + 删除按钮） */
.option-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

/* 选项输入框 */
.option-input {
  flex: 1;
  font-size: 28rpx;
  padding: 8rpx 0;
}

/* 选项删除按钮 */
.option-remove {
  font-size: 28rpx;
  color: #ccc;
  padding: 8rpx 16rpx;
}

/* 添加选项按钮 - 虚线边框 */
.add-option {
  text-align: center;
  padding: 16rpx;
  color: #4ECDC4;
  font-size: 28rpx;
  border: 2rpx dashed #4ECDC4;
  border-radius: 12rpx;
}

/* 创建操作区 */
.create-action {
  margin-top: 30rpx;
}

/* ===== 投票模式 ===== */

/* 房间头部（标题、房间码、分享） */
.room-header {
  text-align: center;
}

/* 房间标题 */
.room-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

/* 房间码行（房间码 + 复制按钮） */
.room-code-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

/* 房间码文字 */
.room-code {
  font-size: 26rpx;
  color: #999;
}

/* 复制按钮 */
.copy-btn {
  font-size: 24rpx;
  color: #4ECDC4;
  padding: 4rpx 12rpx;
  border: 1rpx solid #4ECDC4;
  border-radius: 8rpx;
}

/* 邀请好友分享按钮 */
.share-btn {
  background: #f5f5f5;
  border: none;
  font-size: 28rpx;
  color: #666;
  border-radius: 50rpx;
  padding: 12rpx 24rpx;
  margin: 0;
  line-height: normal;
}

/* 去除分享按钮默认边框 */
.share-btn::after {
  border: none;
}

/* ===== 投票选项列表 ===== */
.vote-options {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 单个投票选项 */
.vote-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

/* 选中的投票选项 - 青色高亮 */
.vote-option.selected {
  background: #E8F8F5;
  border-color: #4ECDC4;
}

/* 选项文字 */
.option-text {
  font-size: 30rpx;
  color: #333;
}

/* 选中勾选图标 */
.option-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #4ECDC4;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 投票操作区 */
.vote-action {
  margin-top: 30rpx;
}

/* ===== 结果模式 ===== */

/* 结果头部 */
.result-header {
  text-align: center;
}

/* 结果标题 */
.result-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

/* 总投票人数 */
.result-total {
  font-size: 26rpx;
  color: #999;
}

/* 胜出/平局结果卡片 - 红色渐变背景 */
.result-card {
  text-align: center;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
}

/* 胜出/平局标签 */
.winner-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
  margin-bottom: 8rpx;
}

/* 胜出选项名称 */
.winner-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

/* 胜出选项票数 */
.winner-votes {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ===== 投票详情 ===== */
.tally-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 单个统计项 */
.tally-item {
  display: flex;
  flex-direction: column;
}

/* 统计条信息行（选项名 + 票数） */
.tally-bar-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

/* 统计项选项名 */
.tally-option {
  font-size: 28rpx;
  color: #333;
}

/* 统计项票数 */
.tally-count {
  font-size: 24rpx;
  color: #999;
}

/* 进度条背景 */
.tally-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

/* 进度条填充 - 青色渐变 */
.tally-fill {
  height: 100%;
  background: linear-gradient(90deg, #4ECDC4, #6EE7DE);
  border-radius: 8rpx;
  transition: width 0.5s;
}

/* 底部分享结果按钮 */
.share-btn-bottom {
  margin-top: 30rpx;
  background: #f5f5f5;
  border: none;
  font-size: 28rpx;
  color: #666;
  border-radius: 50rpx;
  padding: 16rpx;
}

/* 去除底部分享按钮默认边框 */
.share-btn-bottom::after {
  border: none;
}
