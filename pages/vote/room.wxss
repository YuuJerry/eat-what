/* 投票房间 */

.page {
  background: #FFF5F5;
  min-height: 100vh;
  padding: 32rpx 28rpx;
  padding-bottom: 60rpx;
  box-sizing: border-box;
}

/* ── 创建模式 ── */

.page-title {
  display: block;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 32rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 输入框卡片 - 珊瑚红左边框 */
.input-card {
  border-left: 8rpx solid #E94560;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
  display: block;
  margin-bottom: 16rpx;
}

/* 输入框 */
.title-input {
  width: 100%;
  font-size: 30rpx;
  color: #2D3436;
  padding: 12rpx 0;
}

/* 选项列表 */
.option-list {
  display: flex;
  flex-direction: column;
}

.option-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.option-row:last-child {
  border-bottom: none;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: #2D3436;
}

.option-remove {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border-radius: 50%;
  background: #F0F0F0;
}

.option-remove text {
  font-size: 24rpx;
  color: #B2BEC3;
  font-weight: 600;
}

/* 添加选项按钮 */
.add-option {
  margin-top: 4rpx;
  margin-bottom: 24rpx;
  padding: 22rpx;
  text-align: center;
  border: 2rpx dashed #4ECDC4;
  border-radius: 24rpx;
}

.add-option text {
  font-size: 28rpx;
  color: #4ECDC4;
  font-weight: 500;
}

/* 操作区 */
.action-area {
  padding: 8rpx 0;
}

.btn-create {
  text-align: center;
  padding: 26rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 2rpx solid #E94560;
}

.btn-create text {
  color: #E94560;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-create:active {
  opacity: 0.7;
}

/* ── 投票模式 ── */

.room-header {
  text-align: center;
}

.room-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D3436;
  display: block;
  margin-bottom: 12rpx;
}

.room-hint {
  font-size: 24rpx;
  color: #636E72;
  display: block;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.invite-btn {
  display: inline-block;
  background: #E94560;
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(233, 69, 96, 0.25);
}

.invite-btn:active {
  opacity: 0.8;
}

/* 投票选项 */
.vote-options {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.vote-opt {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 28rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  border: 2rpx solid #F0F0F0;
}

.vote-opt.selected {
  background: #E8F8F5;
  border-color: #4ECDC4;
}

.vote-opt:active {
  transform: scale(0.98);
}

.opt-text {
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 500;
}

.opt-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #4ECDC4;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

/* 按钮 */
.btn-primary {
  text-align: center;
  padding: 26rpx;
  background: #4ECDC4;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.25);
}

.btn-primary text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  text-align: center;
  padding: 26rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 2rpx solid #DFE6E9;
}

.btn-secondary text {
  color: #636E72;
  font-size: 30rpx;
  font-weight: 500;
}

.btn-secondary:active {
  opacity: 0.7;
}

/* ── 结果模式 ── */

.result-header {
  text-align: center;
}

.result-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3436;
  display: block;
}

.result-total {
  font-size: 24rpx;
  color: #636E72;
  display: block;
  margin-top: 8rpx;
}

.winner-card {
  text-align: center;
  background: linear-gradient(135deg, #E94560, #FF6B6B);
  box-shadow: 0 8rpx 24rpx rgba(233, 69, 96, 0.25);
}

.winner-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.70);
  display: block;
}

.winner-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin: 8rpx 0;
}

.winner-votes {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  display: block;
}

/* 投票详情 */
.tally-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 16rpx;
}

.tally-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.tally-name {
  font-size: 26rpx;
  color: #2D3436;
  font-weight: 500;
}

.tally-count {
  font-size: 24rpx;
  color: #636E72;
}

.tally-bar {
  height: 16rpx;
  background: #F0F0F0;
  border-radius: 8rpx;
  overflow: hidden;
}

.tally-fill {
  height: 100%;
  background: linear-gradient(90deg, #4ECDC4, #6EE7DE);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}
