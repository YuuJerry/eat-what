/* 投票房间 — 统一设计系统 */

.page { background: #FFF5F5; min-height: 100vh; padding: 24rpx; padding-bottom: 40rpx; }

/* 标题 */
.page-title {
  font-size: 36rpx; font-weight: 700; color: #2D3436;
  display: block; text-align: center; margin-bottom: 24rpx;
}

.card-title { font-size: 28rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 16rpx; }

/* 创建模式 */
.title-input { width: 100%; font-size: 28rpx; padding: 16rpx 0; }
.option-list { display: flex; flex-direction: column; }
.option-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}
.option-row:last-child { border-bottom: none; }
.option-text { font-size: 28rpx; color: #2D3436; flex: 1; }
.option-remove { font-size: 28rpx; color: #636E72; padding: 8rpx; }
.add-option {
  margin-top: 16rpx; padding: 18rpx; text-align: center;
  border: 2rpx dashed #4ECDC4; border-radius: 16rpx;
  font-size: 26rpx; color: #4ECDC4; font-weight: 500;
}
.action-area { padding: 24rpx; }
.btn-create {
  text-align: center; padding: 24rpx;
  background: #fff; border-radius: 24rpx;
  border: 2rpx solid #E94560;
  box-shadow: 0 4rpx 16rpx rgba(233,69,96,0.12);
}
.btn-create text { color: #E94560; font-size: 30rpx; font-weight: 600; }
.btn-create:active { transform: scale(0.97); }

/* 投票模式 */
.room-header { text-align: center; }
.room-title { font-size: 32rpx; font-weight: 700; color: #2D3436; display: block; margin-bottom: 12rpx; }
.room-hint { font-size: 24rpx; color: #636E72; display: block; margin-bottom: 20rpx; }
.invite-btn {
  display: inline-block; background: #E94560; color: #fff;
  padding: 14rpx 28rpx; border-radius: 16rpx; font-size: 26rpx; font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(233,69,96,0.25);
}
.invite-btn:active { transform: scale(0.96); }

.vote-options { display: flex; flex-direction: column; gap: 12rpx; }
.vote-opt {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx; background: #F8F9FA; border-radius: 16rpx;
  border: 2rpx solid #F0F0F0;
}
.vote-opt.selected { background: #E8F8F5; border-color: #4ECDC4; }
.vote-opt:active { transform: scale(0.98); }
.opt-text { font-size: 28rpx; color: #2D3436; font-weight: 500; }
.opt-check { width: 36rpx; height: 36rpx; border-radius: 50%; background: #4ECDC4; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 20rpx; }

/* 结果模式 */
.result-header { text-align: center; }
.result-title { font-size: 30rpx; font-weight: 700; color: #2D3436; display: block; }
.result-total { font-size: 24rpx; color: #636E72; display: block; margin-top: 8rpx; }

.winner-card {
  text-align: center; background: linear-gradient(135deg, #E94560, #FF6B6B);
  box-shadow: 0 8rpx 24rpx rgba(233,69,96,0.25);
}
.winner-label { font-size: 24rpx; color: rgba(255,255,255,0.70); display: block; }
.winner-name { font-size: 40rpx; font-weight: 700; color: #fff; display: block; margin: 8rpx 0; }
.winner-votes { font-size: 28rpx; color: rgba(255,255,255,0.85); display: block; }

.tally-list { display: flex; flex-direction: column; gap: 16rpx; margin-top: 16rpx; }
.tally-info { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.tally-name { font-size: 26rpx; color: #2D3436; font-weight: 500; }
.tally-count { font-size: 24rpx; color: #636E72; }
.tally-bar { height: 16rpx; background: #F0F0F0; border-radius: 8rpx; overflow: hidden; }
.tally-fill { height: 100%; background: linear-gradient(90deg, #4ECDC4, #6EE7DE); border-radius: 8rpx; transition: width 0.5s ease; }
