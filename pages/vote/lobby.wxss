/* 投票大厅 — 统一设计系统 */

.page { background: #FFF5F5; min-height: 100vh; padding: 24rpx; padding-bottom: 120rpx; }

/* 标题 */
.page-title {
  font-size: 36rpx; font-weight: 700; color: #2D3436;
  display: block; text-align: center; margin-bottom: 24rpx;
}

/* 操作卡 */
.action-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; margin-bottom: 28rpx; }
.action-card {
  border-radius: 24rpx; padding: 32rpx 24rpx; position: relative; overflow: hidden;
  display: flex; flex-direction: column; align-items: center;
}
.action-card:active { transform: scale(0.97); }
.action-card.create {
  background: linear-gradient(135deg, #E94560, #FF6B6B);
  box-shadow: 0 8rpx 24rpx rgba(233,69,96,0.25);
}
.action-card.join {
  background: linear-gradient(135deg, #4ECDC4, #6EE7DE);
  box-shadow: 0 8rpx 24rpx rgba(78,205,196,0.25);
}
.ac-icon-wrap {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 12rpx;
}
.ac-icon { font-size: 32rpx; color: #fff; font-weight: 700; }
.ac-title { font-size: 28rpx; font-weight: 600; color: #fff; display: block; }

/* 区块标题 */
.section { margin-bottom: 16rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 16rpx; }

/* 房间列表 */
.room-list { display: flex; flex-direction: column; gap: 12rpx; }
.room-card { display: flex; align-items: center; justify-content: space-between; }
.room-info { flex: 1; }
.room-title { font-size: 28rpx; font-weight: 600; color: #2D3436; display: block; }
.room-meta { display: flex; gap: 16rpx; margin-top: 6rpx; }
.room-date { font-size: 22rpx; color: #636E72; }
.room-members { font-size: 22rpx; color: #636E72; }
