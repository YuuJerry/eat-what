/* 投票大厅 — 统一设计系统 */

.page { background: #F8F9FA; min-height: 100vh; padding: 24rpx; padding-bottom: 120rpx; }

/* 操作卡 */
.action-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; margin-bottom: 28rpx; }
.action-card {
  border-radius: 24rpx; padding: 28rpx 24rpx; position: relative; overflow: hidden;
}
.action-card:active { transform: scale(0.97); }
.action-card.create {
  background: linear-gradient(135deg, #E94560, #FF6B6B);
  box-shadow: 0 8rpx 24rpx rgba(233,69,96,0.25);
}
.action-card.join {
  background: linear-gradient(135deg, #4ECDC4, #6EE7DE);
  box-shadow: 0 8rpx 24rpx rgba(78,205,196,0.25);
}
.ac-icon { font-size: 40rpx; display: block; margin-bottom: 12rpx; }
.ac-title { font-size: 28rpx; font-weight: 600; color: #fff; display: block; margin-bottom: 4rpx; }
.ac-desc { font-size: 22rpx; color: rgba(255,255,255,0.70); display: block; }

/* 区块标题 */
.section { margin-bottom: 16rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 16rpx; }

/* 房间列表 */
.room-list { display: flex; flex-direction: column; gap: 12rpx; }
.room-card { display: flex; align-items: center; justify-content: space-between; }
.room-info { flex: 1; }
.room-title { font-size: 28rpx; font-weight: 600; color: #2D3436; display: block; }
.room-code { font-size: 22rpx; color: #636E72; display: block; margin-top: 4rpx; }
.room-status { font-size: 20rpx; padding: 6rpx 14rpx; border-radius: 100rpx; background: #F8F9FA; color: #636E72; }
.room-status.active { background: #E8F8F5; color: #4ECDC4; }
