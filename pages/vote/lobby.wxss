/* 投票大厅 */

.page {
  min-height: 100vh;
  background: #FFF5F0;
  padding: 0 32rpx 120rpx;
}

/* ── 标题 ── */
.header {
  padding: 48rpx 0 40rpx;
  text-align: center;
}
.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3436;
}

/* ── 操作卡 2列 ── */
.action-grid {
  display: flex;
  gap: 24rpx;
  margin-bottom: 48rpx;
}
.action-card {
  flex: 1;
  border-radius: 28rpx;
  padding: 48rpx 0 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s;
}
.action-card:active {
  transform: scale(0.96);
}

/* 珊瑚红渐变 */
.action-card.create {
  background: linear-gradient(160deg, #FF8A80 0%, #E94560 100%);
  box-shadow: 0 12rpx 32rpx rgba(233, 69, 96, 0.25);
}
/* 翡翠绿渐变 */
.action-card.join {
  background: linear-gradient(160deg, #6DD5C8 0%, #2ECC9B 100%);
  box-shadow: 0 12rpx 32rpx rgba(46, 204, 155, 0.25);
}

/* 圆形图标包裹 */
.action-icon-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.28);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}
.action-icon-symbol {
  font-size: 52rpx;
  font-weight: 300;
  color: #FFFFFF;
  line-height: 1;
}
.action-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

/* ── 历史投票 ── */
.history-section {
  margin-bottom: 32rpx;
}
.history-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 20rpx;
}
.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.history-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: transform 0.15s;
}
.history-card:active {
  transform: scale(0.98);
}
.history-card-body {
  flex: 1;
  min-width: 0;
}
.history-card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.history-card-meta {
  display: flex;
  align-items: center;
}
.history-card-date {
  font-size: 24rpx;
  color: #999999;
}
.history-card-sep {
  font-size: 24rpx;
  color: #CCCCCC;
  margin: 0 10rpx;
}
.history-card-members {
  font-size: 24rpx;
  color: #999999;
}
.history-card-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* ── 空状态 ── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0 0;
}
.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 12rpx;
}
.empty-sub {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
}
