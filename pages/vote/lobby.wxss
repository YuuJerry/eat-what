/* 投票大厅页面样式 */

/* 页面容器 */
.container {
  padding: 24rpx;
}

/* ===== 快捷操作卡片区域 ===== */
.action-cards {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

/* 操作卡片基础样式 */
.action-card {
  flex: 1;
  padding: 30rpx 20rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 发起投票卡片 - 红色渐变背景 */
.action-card.create {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
}

/* 加入投票卡片 - 青色渐变背景 */
.action-card.join {
  background: linear-gradient(135deg, #4ECDC4, #6EE7DE);
}

/* 操作卡片图标 */
.action-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

/* 操作卡片标题 */
.action-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 6rpx;
}

/* 操作卡片描述文字 */
.action-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
}

/* ===== 区域标题 ===== */
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

/* ===== 历史房间卡片 ===== */
.room-card {
  margin-left: 0;
  margin-right: 0;
}

/* 房间标题 */
.room-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

/* 房间元信息行（房间码和状态横向排列） */
.room-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 房间码文字 */
.room-code {
  font-size: 24rpx;
  color: #999;
}

/* 房间状态标签 - 默认灰色 */
.room-status {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

/* 房间状态标签 - 进行中（青色高亮） */
.room-status.active {
  color: #4ECDC4;
  background: #E8F8F5;
}

/* ===== 空状态提示 ===== */
.empty-hint {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 8rpx;
}
