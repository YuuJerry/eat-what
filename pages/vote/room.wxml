<!-- 投票房间 -->
<view class="page">
  <!-- 创建模式 -->
  <view wx:if="{{mode === 'create'}}">
    <text class="page-title">创建投票</text>
    <view class="card">
      <input class="title-input" placeholder="输入选项" value="{{title}}" bindinput="onTitleInput" />
    </view>
    <view class="card">
      <view class="option-list">
        <view class="option-row" wx:for="{{options}}" wx:key="index">
          <text class="option-text">{{item}}</text>
          <view class="option-remove" wx:if="{{options.length > 2}}" bindtap="onRemoveOption" data-idx="{{index}}">
            <text>✕</text>
          </view>
        </view>
      </view>
    </view>
    <view class="add-option" bindtap="onAddOption" wx:if="{{options.length < 6}}">
      <text>+ 添加更多选项</text>
    </view>
    <view class="action-area">
      <view class="btn-create" bindtap="onCreateRoom">
        <text>{{isCreating ? '创建中...' : '创建投票'}}</text>
      </view>
    </view>
  </view>

  <!-- 投票模式 -->
  <view wx:if="{{mode === 'vote' && room}}">
    <view class="card room-header">
      <text class="room-title">{{room.title}}</text>
      <text class="room-hint">复制投票码发给好友，好友在小程序首页粘贴即可加入</text>
      <view class="invite-btn" bindtap="onCopyInvite">
        <text>📋 复制投票码发给好友</text>
      </view>
    </view>
    <view class="card">
      <text class="card-title">选择你想吃的</text>
      <view class="vote-options">
        <view class="vote-opt {{myVote === item ? 'selected' : ''}}" wx:for="{{room.options}}" wx:key="*this" bindtap="onSelectOption" data-option="{{item}}">
          <text class="opt-text">{{item}}</text>
          <view class="opt-check" wx:if="{{myVote === item}}"><text>✓</text></view>
        </view>
      </view>
    </view>
    <view class="action-area">
      <view class="btn-primary" bindtap="onSubmitVote"><text>确认投票</text></view>
      <view class="btn-secondary" bindtap="loadResult" style="margin-top:16rpx"><text>查看当前结果</text></view>
    </view>
  </view>

  <!-- 结果模式 -->
  <view wx:if="{{mode === 'result' && result}}">
    <view class="card result-header">
      <text class="result-title">{{result.room.title}}</text>
      <text class="result-total">共 {{result.totalVotes}} 人投票</text>
    </view>
    <view class="card winner-card">
      <text class="winner-label">{{result.isTie ? '🏆 平局' : '🏆 胜出'}}</text>
      <text class="winner-name">{{result.winner}}</text>
      <text class="winner-votes">{{result.winnerVotes}} 票</text>
    </view>
    <view class="card">
      <text class="card-title">投票详情</text>
      <view class="tally-list">
        <view class="tally-item" wx:for="{{result.tally}}" wx:key="index">
          <view class="tally-info">
            <text class="tally-name">{{item[0]}}</text>
            <text class="tally-count">{{item[1]}} 票</text>
          </view>
          <view class="tally-bar">
            <view class="tally-fill" style="width: {{result.totalVotes > 0 ? (item[1] / result.totalVotes * 100) : 0}}%"></view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
