/* 随机转盘 — 统一设计系统 */

.page {
  background: #FFF5F5; min-height: 100vh;
  display: flex; flex-direction: column; align-items: center;
  padding: 24rpx; padding-bottom: 120rpx;
}

/* 标题 */
.page-title {
  font-size: 36rpx; font-weight: 700; color: #2D3436;
  display: block; text-align: center; margin-bottom: 20rpx;
}

/* 结果 */
.result-area { width: 100%; margin-bottom: 20rpx; }
.result-card {
  background: #fff;
  border-radius: 24rpx; padding: 28rpx; text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
.result-card.spinning { animation: pulse 0.15s infinite alternate; }
@keyframes pulse { from { transform: scale(1); } to { transform: scale(1.03); } }
.result-text { font-size: 32rpx; font-weight: 600; color: #E94560; display: block; }

/* 转盘 */
.wheel-wrap {
  position: relative; width: 480rpx; height: 480rpx;
  margin-bottom: 24rpx;
}
.wheel-canvas {
  width: 100%; height: 100%; border-radius: 50%;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}
.wheel-pointer {
  position: absolute; top: -16rpx; left: 50%; transform: translateX(-50%);
  font-size: 40rpx; color: #E94560; z-index: 10;
}

/* 按钮 */
.btn-row { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.spin-btn {
  background: linear-gradient(135deg, #E94560, #FF6B6B);
  color: #fff; border-radius: 100rpx; padding: 18rpx 40rpx;
  font-size: 28rpx; font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(233,69,96,0.25);
}
.spin-btn:active { transform: scale(0.96); }
.random-btn {
  background: linear-gradient(135deg, #4ECDC4, #6EE7DE);
  color: #fff; border-radius: 100rpx; padding: 18rpx 40rpx;
  font-size: 28rpx; font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(78,205,196,0.25);
}
.random-btn:active { transform: scale(0.96); }

/* 分类标签 */
.cat-scroll { width: 100%; padding: 0 0 16rpx; white-space: nowrap; }
.cat-pill {
  display: inline-flex; padding: 10rpx 24rpx; margin-right: 12rpx;
  border-radius: 100rpx; background: #fff; border: 2rpx solid #DFE6E9;
  font-size: 24rpx; color: #636E72; font-weight: 500;
}
.cat-pill.active { background: #E94560; border-color: #E94560; color: #fff; }

/* 食物列表 */
.food-card { width: 100%; }
.food-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.food-title { font-size: 28rpx; font-weight: 600; color: #2D3436; }
.food-add {
  font-size: 24rpx; color: #4ECDC4; font-weight: 500;
  border: 2rpx solid #4ECDC4; border-radius: 100rpx; padding: 6rpx 16rpx;
}
.food-scroll { max-height: 500rpx; }
.food-item {
  display: flex; align-items: center; gap: 12rpx;
  padding: 12rpx 0; border-bottom: 1rpx solid #F0F0F0;
}
.food-item:last-child { border-bottom: none; }
.food-icon-wrap { width: 40rpx; height: 40rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; }
.food-icon { width: 100%; height: 100%; }
.food-name { flex: 1; font-size: 26rpx; color: #2D3436; }
.food-cat-tag { font-size: 20rpx; color: #636E72; background: #F0F0F0; padding: 2rpx 10rpx; border-radius: 100rpx; }
.food-actions { display: flex; gap: 8rpx; }
.food-edit { font-size: 24rpx; padding: 4rpx; }
.food-del { font-size: 24rpx; color: #636E72; padding: 4rpx; }
.food-del:active { color: #E94560; }

/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; display: flex; align-items: center; justify-content: center; }
.modal { background: #fff; border-radius: 24rpx; padding: 28rpx; width: 600rpx; }
.modal-title { font-size: 30rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 20rpx; }
.modal-input { width: 100%; font-size: 28rpx; padding: 16rpx; border: 2rpx solid #DFE6E9; border-radius: 12rpx; margin-bottom: 20rpx; }
.modal-btns { display: flex; gap: 16rpx; }
.modal-btn { flex: 1; padding: 16rpx; border-radius: 16rpx; text-align: center; font-size: 28rpx; font-weight: 500; }
.modal-btn.cancel { background: #F8F9FA; color: #636E72; }
.modal-btn.confirm { background: #E94560; color: #fff; }
