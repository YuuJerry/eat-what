/* 个人中心 — 统一设计系统 */

.page { background: #F8F9FA; min-height: 100vh; padding-bottom: 120rpx; }

/* 用户头部 */
.profile-hero {
  background: #1A1A2E; padding: 40rpx 32rpx; display: flex; align-items: center; gap: 20rpx;
  border-radius: 0 0 32rpx 32rpx; margin-bottom: 20rpx;
}
.avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: linear-gradient(135deg, #E94560, #FF6B6B);
  display: flex; align-items: center; justify-content: center; font-size: 36rpx;
}
.user-name { font-size: 32rpx; font-weight: 700; color: #fff; display: block; }
.user-desc { font-size: 24rpx; color: rgba(255,255,255,0.55); display: block; margin-top: 4rpx; }

/* 卡片 */
.card { margin: 0 24rpx 16rpx; }
.card-head { display: flex; align-items: center; gap: 12rpx; }
.card-title { font-size: 28rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 16rpx; }
.card-head .card-title { margin-bottom: 0; flex: 1; }
.card-count { font-size: 24rpx; color: #636E72; }
.card-arrow { font-size: 22rpx; color: #636E72; padding: 8rpx; }

/* 收藏列表 */
.fav-list { margin-top: 16rpx; display: flex; flex-direction: column; gap: 10rpx; }
.fav-item { display: flex; align-items: center; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #F0F0F0; }
.fav-item:last-child { border-bottom: none; }
.fav-info { flex: 1; }
.fav-name { font-size: 26rpx; font-weight: 600; color: #2D3436; display: block; }
.fav-meta { font-size: 22rpx; color: #636E72; display: block; margin-top: 2rpx; }
.fav-del { font-size: 28rpx; color: #636E72; padding: 8rpx; }
.fav-del:active { color: #E94560; }
.empty-mini { text-align: center; padding: 24rpx 0; font-size: 24rpx; color: #636E72; }

/* 滑块 */
.slider-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.slider-label { font-size: 26rpx; color: #2D3436; width: 60rpx; }
.slider { flex: 1; }
.slider-val { font-size: 26rpx; color: #636E72; width: 40rpx; text-align: center; }

/* 目标 */
.goal-pills { display: flex; gap: 12rpx; }
.goal-pill {
  flex: 1; text-align: center; padding: 14rpx; border-radius: 100rpx;
  background: #F8F9FA; border: 2rpx solid #DFE6E9; font-size: 26rpx; color: #636E72; font-weight: 500;
}
.goal-pill.active { background: #4ECDC4; border-color: #4ECDC4; color: #fff; }

/* 标签 */
.tag-list { display: flex; flex-wrap: wrap; gap: 10rpx; }
.pref-tag {
  padding: 10rpx 20rpx; border-radius: 100rpx; font-size: 24rpx;
  background: #F8F9FA; border: 2rpx solid #DFE6E9; color: #636E72; font-weight: 500;
}
.pref-tag.active { background: #FFB300; border-color: #FFB300; color: #fff; }

/* 保存 */
.save-area { padding: 24rpx; }
