/* 个人偏好设置页面样式 */

/* 页面容器 */
.container {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

/* ===== 用户信息卡片 ===== */
.user-card {
  display: flex;
  align-items: center;
  margin-left: 0;
  margin-right: 0;
}

/* 用户头像 - 圆形渐变背景 */
.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 20rpx;
}

/* 用户信息区域 */
.user-info {
  flex: 1;
}

/* 用户名 */
.user-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

/* 用户描述文字 */
.user-desc {
  font-size: 24rpx;
  color: #999;
}

/* ===== 快捷链接区域 ===== */
.quick-links {
  margin-left: 0;
  margin-right: 0;
  padding: 0;
}

/* 单个快捷链接行 */
.quick-link {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

/* 最后一个链接无下边框 */
.quick-link:last-child {
  border-bottom: none;
}

/* 链接图标 */
.link-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

/* 链接文字 */
.link-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 链接箭头 */
.link-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* ===== 通用卡片和标题 ===== */
.card {
  margin-left: 0;
  margin-right: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

/* ===== 口味偏好滑块 ===== */
.slider-group {
  display: flex;
  flex-direction: column;
}

/* 单个滑块行（标签 + 滑块 + 数值） */
.slider-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

/* 滑块标签 */
.slider-label {
  font-size: 28rpx;
  color: #333;
  width: 120rpx;
  flex-shrink: 0;
}

/* 滑块当前值 */
.slider-value {
  font-size: 28rpx;
  color: #999;
  width: 40rpx;
  text-align: center;
}

/* ===== 饮食目标选择 ===== */
.goal-list {
  display: flex;
  gap: 12rpx;
}

/* 单个目标选项 - 默认灰色 */
.goal-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

/* 选中的目标选项 - 青色高亮 */
.goal-item.active {
  background: #E8F8F5;
  color: #4ECDC4;
  border-color: #4ECDC4;
}

/* ===== 标签列表（过敏源/忌口） ===== */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* 单个标签项 - 默认灰色 */
.tag-item {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

/* 选中的过敏源标签 - 橙色高亮 */
.tag-item.selected.allergy {
  background: #FFF0E5;
  color: #FF8C00;
  border-color: #FF8C00;
}

/* 选中的忌口标签 - 红色高亮 */
.tag-item.selected.dislike {
  background: #FFE5E5;
  color: #FF6B6B;
  border-color: #FF6B6B;
}

/* ===== 保存按钮区域 ===== */
.save-action {
  margin-top: 30rpx;
}
