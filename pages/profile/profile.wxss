/* 个人中心 — 按设计稿严格还原 */

/* 页面底色 */
.page {
  background: #F5F5F5;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ============ 深色头部 #1A1A2E ============ */
.header {
  background: #1A1A2E;
  padding: 80rpx 0 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 0 0 32rpx 32rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E94560, #FF6B6B);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.avatar-emoji {
  font-size: 72rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 24rpx;
  color: #999999;
}

/* ============ 通用卡片 白色圆角24rpx ============ */
.card {
  margin: 24rpx 28rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 24rpx;
}

.card-head .card-title {
  margin-bottom: 0;
}

.card-arrow {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx;
}

/* ============ 收藏列表 ============ */
.fav-list {
  margin-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
  padding-top: 12rpx;
}

.fav-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.fav-item:last-child {
  border-bottom: none;
}

.fav-info {
  flex: 1;
}

.fav-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
}

.fav-meta {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.fav-del {
  font-size: 28rpx;
  color: #CCC;
  padding: 8rpx 12rpx;
}

.fav-del:active {
  color: #E94560;
}

.fav-empty {
  text-align: center;
  padding: 32rpx 0 8rpx;
  font-size: 24rpx;
  color: #BBB;
}

/* ============ 口味偏好滑块 ============ */
.slider-block {
  margin-bottom: 28rpx;
}

.slider-block:last-child {
  margin-bottom: 0;
}

.slider-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.slider-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.slider-value {
  font-size: 28rpx;
  font-weight: 700;
}

.slider-value-spicy {
  color: #E94560;
}

.slider-value-sweet {
  color: #FFB300;
}

.slider-value-sour {
  color: #4ECDC4;
}

/* ============ 饮食目标 pill选择 ============ */
.goal-row {
  display: flex;
  gap: 16rpx;
}

.goal-pill {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 100rpx;
  background: #F5F5F5;
  border: 2rpx solid #E8E8E8;
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.goal-pill.active {
  background: #4ECDC4;
  border-color: #4ECDC4;
  color: #FFFFFF;
}

/* ============ 忌口多选标签 ============ */
.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 14rpx 32rpx;
  border-radius: 100rpx;
  background: #F5F5F5;
  border: 2rpx solid #E8E8E8;
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.tag.active {
  background: #FFB300;
  border-color: #FFB300;
  color: #FFFFFF;
}

/* ============ 保存按钮 珊瑚红#E94560 圆角100rpx ============ */
.save-wrap {
  padding: 40rpx 28rpx 0;
}

.save-btn {
  background: #E94560;
  color: #FFFFFF;
  text-align: center;
  padding: 26rpx 0;
  border-radius: 100rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(233, 69, 96, 0.3);
}

.save-btn:active {
  opacity: 0.85;
}
