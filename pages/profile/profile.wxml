<!-- 个人偏好设置页面 -->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card card">
    <view class="avatar">
      <text>👤</text>
    </view>
    <view class="user-info">
      <text class="user-name">美食家</text>
      <text class="user-desc">设置偏好，获取个性化推荐</text>
    </view>
  </view>

  <!-- 我的收藏 -->
  <view class="card">
    <view class="section-header-row" bindtap="onToggleFavorites">
      <text class="section-title">❤️ 我的收藏 ({{favorites.length}})</text>
      <text class="section-arrow">{{showFavorites ? '▲' : '▼'}}</text>
    </view>

    <!-- 收藏列表 -->
    <view wx:if="{{showFavorites && favorites.length > 0}}" class="fav-list">
      <view class="fav-card" wx:for="{{favorites}}" wx:key="name">
        <view class="fav-header">
          <view class="fav-cover">
            <image src="{{item.coverIcon}}" mode="aspectFit" class="fav-cover-img" />
          </view>
          <view class="fav-info">
            <text class="fav-name">{{item.name}}</text>
            <view class="fav-meta">
              <text wx:if="{{item.cookTime}}">⏱ {{item.cookTime}}分钟</text>
              <text wx:if="{{item.calories}}">🔥 {{item.calories}}kcal</text>
            </view>
          </view>
          <text class="fav-delete" bindtap="onDeleteFavorite" data-name="{{item.name}}">🗑</text>
        </view>

        <!-- 用料 -->
        <view class="fav-ingredients" wx:if="{{item.ingredients.length > 0}}">
          <text class="fav-sub">📋 用料：</text>
          <text class="fav-ing-text">{{item.ingredientsText}}</text>
        </view>

        <!-- 步骤 -->
        <view class="fav-steps" wx:if="{{item.steps.length > 0}}">
          <view class="fav-steps-toggle" bindtap="onToggleFavSteps" data-index="{{index}}">
            <text>{{item.showSteps ? '🔽 收起步骤' : '▶️ 查看步骤'}}</text>
          </view>
          <view wx:if="{{item.showSteps}}" class="fav-steps-list">
            <view class="fav-step" wx:for="{{item.steps}}" wx:for-item="step" wx:for-index="sidx" wx:key="*this">
              <text class="step-num">{{sidx + 1}}.</text>
              <text class="step-text">{{step}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{showFavorites && favorites.length === 0}}" class="fav-empty">
      <text class="empty-emoji">💭</text>
      <text class="empty-text">还没有收藏的菜谱</text>
      <text class="empty-hint">去冰箱推荐页面找找灵感吧</text>
    </view>
  </view>

  <!-- 口味偏好设置 -->
  <view class="card">
    <text class="section-title">👅 口味偏好</text>
    <view class="slider-group">
      <view class="slider-item">
        <text class="slider-label">🌶️ 辣度</text>
        <slider min="0" max="5" value="{{preferences.spicy}}" activeColor="#FF6B6B" block-size="20" bindchange="onSpicyChange" />
        <text class="slider-value">{{preferences.spicy}}</text>
      </view>
      <view class="slider-item">
        <text class="slider-label">🍬 甜度</text>
        <slider min="0" max="5" value="{{preferences.sweet}}" activeColor="#FFE66D" block-size="20" bindchange="onSweetChange" />
        <text class="slider-value">{{preferences.sweet}}</text>
      </view>
      <view class="slider-item">
        <text class="slider-label">🍋 酸度</text>
        <slider min="0" max="5" value="{{preferences.sour}}" activeColor="#4ECDC4" block-size="20" bindchange="onSourChange" />
        <text class="slider-value">{{preferences.sour}}</text>
      </view>
    </view>
  </view>

  <!-- 饮食目标 -->
  <view class="card">
    <text class="section-title">🎯 饮食目标</text>
    <view class="goal-list">
      <view class="goal-item {{dietGoal === item ? 'active' : ''}}" wx:for="{{dietGoals}}" wx:key="*this" bindtap="onDietGoalChange" data-idx="{{index}}">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 过敏源 -->
  <view class="card">
    <text class="section-title">⚠️ 过敏源</text>
    <view class="tag-list">
      <view class="tag-item {{allergies.includes(item) ? 'selected allergy' : ''}}" wx:for="{{commonAllergies}}" wx:key="*this" bindtap="onToggleAllergy" data-name="{{item}}">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 忌口 -->
  <view class="card">
    <text class="section-title">🙅 不喜欢</text>
    <view class="tag-list">
      <view class="tag-item {{dislikes.includes(item) ? 'selected dislike' : ''}}" wx:for="{{commonDislikes}}" wx:key="*this" bindtap="onToggleDislike" data-name="{{item}}">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="save-action">
    <view class="btn-primary" bindtap="onSave">
      <text>{{isSaving ? '保存中...' : '保存偏好'}}</text>
    </view>
  </view>
</view>
