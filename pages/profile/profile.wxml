<!-- 个人中心 -->
<view class="page">
  <!-- 用户头部 -->
  <view class="profile-hero">
    <view class="avatar"><text>👤</text></view>
    <view class="user-info">
      <text class="user-name">美食家</text>
      <text class="user-desc">探索每一餐的美好</text>
    </view>
  </view>

  <!-- 收藏 -->
  <view class="card">
    <view class="card-head" bindtap="onToggleFavorites">
      <text class="card-title">❤️ 我的收藏</text>
      <text class="card-count">{{favorites.length}}</text>
      <text class="card-arrow">{{showFavorites ? '▲' : '▼'}}</text>
    </view>
    <view wx:if="{{showFavorites && favorites.length > 0}}" class="fav-list">
      <view class="fav-item" wx:for="{{favorites}}" wx:key="name">
        <view class="fav-info">
          <text class="fav-name">{{item.name}}</text>
          <text class="fav-meta" wx:if="{{item.cookTime}}">⏱ {{item.cookTime}}分 · 🔥 {{item.calories}}kcal</text>
        </view>
        <text class="fav-del" bindtap="onDeleteFavorite" data-name="{{item.name}}">✕</text>
      </view>
    </view>
    <view wx:if="{{showFavorites && favorites.length === 0}}" class="empty-mini">
      <text>还没有收藏哦~</text>
    </view>
  </view>

  <!-- 口味偏好 -->
  <view class="card">
    <text class="card-title">🌶️ 口味偏好</text>
    <view class="slider-row">
      <text class="slider-label">辣度</text>
      <slider class="slider" min="0" max="5" step="1" value="{{preferences.spicy}}" activeColor="#E94560" bindchanging="onSliderChange" data-key="spicy" />
      <text class="slider-val">{{preferences.spicy}}</text>
    </view>
    <view class="slider-row">
      <text class="slider-label">甜度</text>
      <slider class="slider" min="0" max="5" step="1" value="{{preferences.sweet}}" activeColor="#FFB300" bindchanging="onSliderChange" data-key="sweet" />
      <text class="slider-val">{{preferences.sweet}}</text>
    </view>
    <view class="slider-row">
      <text class="slider-label">酸度</text>
      <slider class="slider" min="0" max="5" step="1" value="{{preferences.sour}}" activeColor="#4ECDC4" bindchanging="onSliderChange" data-key="sour" />
      <text class="slider-val">{{preferences.sour}}</text>
    </view>
  </view>

  <!-- 饮食目标 -->
  <view class="card">
    <text class="card-title">🎯 饮食目标</text>
    <view class="goal-pills">
      <view class="goal-pill {{dietGoal === item ? 'active' : ''}}" wx:for="{{['减脂','增肌','均衡']}}" wx:key="*this" bindtap="onSelectGoal" data-goal="{{item}}">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 忌口 -->
  <view class="card">
    <text class="card-title">🚫 忌口</text>
    <view class="tag-list">
      <view class="pref-tag {{dislikeMap[item] ? 'active' : ''}}" wx:for="{{['香菜','葱','蒜','姜','辣椒','花椒','海鲜','牛奶']}}" wx:key="*this" bindtap="onToggleDislike" data-name="{{item}}">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 保存 -->
  <view class="save-area">
    <view class="btn-primary" bindtap="onSave">
      <text>{{isSaving ? '保存中...' : '保存设置'}}</text>
    </view>
  </view>
</view>
