/* 减脂餐 — 统一设计系统 */

.page { background: #F8F9FA; min-height: 100vh; padding-bottom: 120rpx; }

.page-hint { text-align: center; padding: 20rpx 0 12rpx; font-size: 24rpx; color: #636E72; }

/* 菜谱行 */
.recipe-list { padding: 0 24rpx; }
.recipe-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.recipe-row:active { transform: scale(0.98); }
.rr-img { width: 160rpx; height: 160rpx; border-radius: 16rpx; background: #F8F9FA; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
.rr-icon { width: 120rpx; height: 120rpx; }
.rr-body { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.rr-name { font-size: 28rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 6rpx; }
.rr-meta { display: flex; gap: 16rpx; font-size: 22rpx; color: #636E72; margin-bottom: 8rpx; }
.rr-cal { color: #FFB300; font-weight: 500; }
.rr-nutr { display: flex; gap: 12rpx; font-size: 20rpx; color: #4ECDC4; margin-bottom: 8rpx; }
.rr-tags { display: flex; flex-wrap: wrap; gap: 6rpx; }

/* 博主推荐 */
.section { padding: 32rpx 24rpx 0; }
.section-title { font-size: 28rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 16rpx; }
.blogger-list { display: flex; flex-direction: column; gap: 12rpx; }
.blogger-card { display: flex; align-items: center; gap: 16rpx; }
.blogger-avatar { font-size: 40rpx; }
.blogger-info { flex: 1; }
.blogger-name { font-size: 26rpx; font-weight: 600; color: #2D3436; display: block; }
.blogger-desc { font-size: 22rpx; color: #636E72; display: block; margin-top: 2rpx; }
.blogger-platform { font-size: 20rpx; color: #E94560; background: rgba(233,69,96,0.08); padding: 4rpx 12rpx; border-radius: 100rpx; font-weight: 500; }

/* 骨架屏 */
.rr-line { height: 24rpx; border-radius: 8rpx; margin-bottom: 10rpx; }
.rr-line.sm { width: 50%; }
