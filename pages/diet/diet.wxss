/* 页面容器 */
.container {
  padding: 20rpx 24rpx;
  padding-bottom: 40rpx;
}

/* ===== 筛选栏样式 ===== */
.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.filter-item {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  background: #fff;
  border: 2rpx solid #eee;
  font-size: 26rpx;
  color: #666;
}

/* 筛选项激活态：绿色高亮 */
.filter-item.active {
  background: #4ECDC4;
  color: #fff;
  border-color: #4ECDC4;
}

/* ===== 菜谱列表样式 ===== */
/* 菜谱卡片：横向布局 */
.recipe-card {
  display: flex;
  margin-left: 0;
  margin-right: 0;
}

/* 菜谱封面：固定宽高 */
.recipe-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

/* 封面 emoji 图标大小 */
.cover-emoji {
  font-size: 60rpx;
}

/* 封面手绘图标 */
.cover-icon-img {
  width: 120rpx;
  height: 120rpx;
}

/* 菜谱信息区域：占据剩余空间 */
.recipe-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* 菜谱名称 */
.recipe-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

/* 菜谱元信息：热量和时间 */
.recipe-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

/* 热量标签：橙色背景突出显示 */
.meta-cal {
  font-size: 24rpx;
  color: #FF8C00;
  background: #FFF0E5;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

/* 烹饪时间 */
.meta-time {
  font-size: 24rpx;
  color: #999;
}

/* 营养成分行：蛋白、脂肪、碳水横向排列 */
.recipe-nutrition {
  display: flex;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

/* 单个营养成分项 */
.nutrition-item {
  font-size: 22rpx;
  color: #4ECDC4;
}

.recipe-tags {
  display: flex;
  gap: 8rpx;
}

/* ===== 博主推荐样式 ===== */
.blogger-section {
  margin-top: 40rpx;
}

/* 区块标题：加粗大字 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

/* 博主列表：垂直排列 */
.blogger-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 单个博主卡片：白色背景圆角 */
.blogger-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 博主头像 emoji */
.blogger-avatar {
  font-size: 48rpx;
  margin-right: 16rpx;
}

/* 博主信息区域 */
.blogger-info {
  flex: 1;
}

/* 博主名称 */
.blogger-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

/* 博主简介 */
.blogger-desc {
  font-size: 24rpx;
  color: #999;
}

/* 博主平台标签：红色背景 */
.blogger-platform {
  font-size: 22rpx;
  color: #fff;
  background: #FF6B6B;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}
