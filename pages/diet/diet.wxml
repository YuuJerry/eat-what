<!-- 减脂餐 -->
<view class="page">
  <!-- 顶部提示 -->
  <view class="page-hint">
    <text>🥗 减脂菜谱 · 下拉刷新换一批</text>
  </view>

  <!-- 骨架屏 -->
  <view wx:if="{{isLoading}}" class="recipe-list">
    <view class="recipe-card" wx:for="{{[1,2,3]}}" wx:key="*this">
      <view class="skeleton skeleton-icon"></view>
      <view class="skeleton-body">
        <view class="skeleton skeleton-line w60"></view>
        <view class="skeleton skeleton-line w40"></view>
        <view class="skeleton skeleton-line w80"></view>
        <view class="skeleton-tags">
          <view class="skeleton skeleton-tag"></view>
          <view class="skeleton skeleton-tag short"></view>
        </view>
      </view>
    </view>
  </view>

  <!-- 菜谱列表 -->
  <view class="recipe-list" wx:if="{{!isLoading && recipes.length > 0}}">
    <view class="recipe-card" wx:for="{{recipes}}" wx:key="name" bindtap="onRecipeTap" data-index="{{index}}">
      <view class="rc-icon-wrap">
        <image src="{{item.coverIcon}}" mode="aspectFit" class="rc-icon" />
      </view>
      <view class="rc-body">
        <text class="rc-name">{{item.name}}</text>
        <view class="rc-meta">
          <text class="rc-cal">🔥 {{item.calories}}kcal</text>
          <text class="rc-dot">·</text>
          <text class="rc-time">⏱ {{item.cookTime}}分</text>
        </view>
        <view class="rc-nutr" wx:if="{{item.nutritionInfo}}">
          <text>蛋白{{item.nutritionInfo.protein}}g</text>
          <text class="rc-nutr-dot">·</text>
          <text>脂肪{{item.nutritionInfo.fat}}g</text>
          <text class="rc-nutr-dot">·</text>
          <text>碳水{{item.nutritionInfo.carbs}}g</text>
        </view>
        <view class="rc-tags">
          <text class="tag tag-green">减脂</text>
          <text class="tag tag-gray" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" wx:if="{{index < 2}}">{{tag}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 博主推荐 -->
  <view class="section" wx:if="{{bloggers.length > 0}}">
    <text class="section-title">📹 推荐博主</text>
    <view class="blogger-list">
      <view class="blogger-card" wx:for="{{bloggers}}" wx:key="name" bindtap="onBloggerTap" data-blogger="{{item}}">
        <text class="blogger-avatar">{{item.avatar}}</text>
        <view class="blogger-info">
          <text class="blogger-name">{{item.name}}</text>
          <text class="blogger-desc">{{item.desc}}</text>
        </view>
        <text class="blogger-platform">{{item.platform === 'bilibili' ? 'B站' : '抖音'}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!isLoading && recipes.length === 0}}">
    <text class="empty-emoji">🏃</text>
    <text class="empty-text">暂无减脂餐</text>
  </view>
</view>
