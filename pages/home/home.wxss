/* 首页 — 星巴克全设计语言 */
/* 色带节奏：深绿 Hero → 奶油功能区 → 白色产品网格 */

.page {
  background: #f2f0eb;
  min-height: 100vh;
}

/* ===== 深绿 Hero 色带 ===== */
.hero-band {
  background: #1E3932;
  padding: 48rpx 32rpx 36rpx;
}

.hero-inner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.hero-eyebrow {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.50);
  display: block;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: 4rpx;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
  letter-spacing: -0.16px;
  line-height: 1.1;
}

.hero-body {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.70);
  margin-top: 8rpx;
  display: block;
}

.hero-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #00754A;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow:
    0 0 8rpx rgba(0, 0, 0, 0.24),
    0 12rpx 20rpx rgba(0, 0, 0, 0.14);
}

.hero-btn:active {
  transform: scale(0.95);
  box-shadow: 0 0 8rpx rgba(0, 0, 0, 0.24);
}

/* 搜索条 */
.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 2rpx solid rgba(255, 255, 255, 0.20);
  border-radius: 100rpx;
  padding: 18rpx 28rpx;
}

.search-icon {
  font-size: 28rpx;
}

.search-placeholder {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.50);
}

/* ===== 功能入口 — 2x2 色块网格 ===== */
.feature-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 28rpx 24rpx;
}

.feature-card {
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  position: relative;
  overflow: hidden;
}

.feature-card:active {
  transform: scale(0.97);
}

/* 深绿卡片 */
.feature-green {
  background: #00754A;
  box-shadow:
    0 4rpx 8rpx rgba(0, 117, 74, 0.2),
    0 12rpx 20rpx rgba(0, 117, 74, 0.15);
}

.feature-green .feature-name,
.feature-green .feature-desc {
  color: #ffffff;
}

.feature-green .feature-desc {
  color: rgba(255, 255, 255, 0.70);
}

/* 奶油卡片 */
.feature-cream {
  background: #ffffff;
  box-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.06),
    0 8rpx 16rpx rgba(0, 0, 0, 0.08);
}

.feature-cream .feature-name {
  color: rgba(0, 0, 0, 0.87);
}

.feature-cream .feature-desc {
  color: rgba(0, 0, 0, 0.58);
}

.feature-emoji {
  font-size: 44rpx;
  display: block;
  margin-bottom: 12rpx;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 4rpx;
  letter-spacing: -0.16px;
}

.feature-desc {
  font-size: 22rpx;
  display: block;
}

/* ===== 区块标题 ===== */
.section {
  margin-bottom: 8rpx;
}

.section-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 20rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #006241;
  letter-spacing: -0.16px;
}

.section-action {
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  border: 2rpx solid #00754A;
}

.section-action:active {
  background: rgba(0, 117, 74, 0.06);
}

.action-text {
  font-size: 24rpx;
  color: #00754A;
  font-weight: 500;
}

/* ===== 骨架屏 ===== */
.product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
}

.product-skeleton {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.skel-img {
  width: 100%;
  height: 220rpx;
  background: linear-gradient(90deg, #edebe9 25%, #f2f0eb 50%, #edebe9 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skel-line {
  height: 28rpx;
  margin: 16rpx 20rpx 0;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #edebe9 25%, #f2f0eb 50%, #edebe9 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skel-line.sm {
  width: 60%;
  margin-bottom: 20rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== 产品卡片（星巴克菜单风格） ===== */
.product-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow:
    0 0 4rpx rgba(0, 0, 0, 0.14),
    0 2rpx 4rpx rgba(0, 0, 0, 0.24);
}

.product-card:active {
  transform: scale(0.97);
  box-shadow:
    0 0 2rpx rgba(0, 0, 0, 0.14);
}

.product-media {
  position: relative;
  width: 100%;
  height: 220rpx;
  background: #f2f0eb;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-img {
  width: 130rpx;
  height: 130rpx;
  transition: opacity 0.3s ease-in;
}

.product-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: #00754A;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 100rpx;
  font-weight: 500;
}

.product-info {
  padding: 16rpx 20rpx 20rpx;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.87);
  display: block;
  margin-bottom: 4rpx;
  letter-spacing: -0.16px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-meta {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.58);
  display: block;
}

/* ===== 底部留白 ===== */
.bottom-spacer {
  height: 120rpx;
}
