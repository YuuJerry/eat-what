/* 首页 — 星巴克设计语言 */

.container {
  padding-bottom: 120rpx;
}

/* ===== Hero — 深绿背景（星巴克特征色带） ===== */
.hero {
  background: #1E3932;
  padding: 48rpx 32rpx 40rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #ffffff;
  display: block;
  letter-spacing: -0.16px;
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.70);
  margin-top: 6rpx;
  display: block;
}

.hero-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #00754A;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* ===== 快捷入口 — 胶囊按钮横排 ===== */
.actions-row {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx 28rpx;
  overflow-x: auto;
}

.action-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  background: #ffffff;
  border-radius: 100rpx;
  box-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.06),
    0 6rpx 12rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.action-pill:active {
  transform: scale(0.95);
}

.action-icon {
  font-size: 32rpx;
}

.action-label {
  font-size: 24rpx;
  font-weight: 500;
  color: rgba(0, 0, 0, 0.87);
}

/* ===== 区块 ===== */
.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #006241;
  letter-spacing: -0.16px;
}

.section-link {
  font-size: 24rpx;
  color: #00754A;
  font-weight: 500;
}

/* ===== 骨架屏 ===== */
.skeleton-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
}

.skeleton-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.skeleton-img {
  width: 100%;
  height: 200rpx;
  border-radius: 16rpx;
  background: linear-gradient(90deg, #edebe9 25%, #f2f0eb 50%, #edebe9 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skeleton-line {
  height: 28rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #edebe9 25%, #f2f0eb 50%, #edebe9 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  margin-top: 12rpx;
}

.skeleton-line.short { width: 60%; }

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== 菜谱卡片网格 ===== */
.recipe-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
}

.recipe-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.06),
    0 8rpx 16rpx rgba(0, 0, 0, 0.08);
}

.recipe-card:active {
  transform: scale(0.97);
}

.recipe-img {
  position: relative;
  width: 100%;
  height: 200rpx;
  background: #f2f0eb;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-img {
  width: 120rpx;
  height: 120rpx;
}

.diet-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: #00754A;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  font-weight: 500;
}

.recipe-body {
  padding: 16rpx 20rpx 20rpx;
}

.recipe-name {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.87);
  display: block;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-meta {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.58);
  display: block;
}
