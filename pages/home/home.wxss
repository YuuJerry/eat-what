/* 首页样式 */

.page {
  background: #f5f5f7;
  min-height: 100vh;
  padding: 0 16rpx;
}

/* ========== Hero 区 ========== */

.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 28rpx 36rpx;
  margin: 16rpx 0 20rpx;
  border-radius: 28rpx;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  overflow: hidden;
  position: relative;
}

.hero::after {
  content: "";
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
}

.hero-content {
  flex: 1;
  z-index: 1;
}

.hero-greeting {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  letter-spacing: 4rpx;
  margin-bottom: 6rpx;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

.hero-search {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 20rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 14rpx;
}

.search-icon {
  font-size: 24rpx;
  opacity: 0.4;
}

.search-placeholder {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.3);
}

.hero-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 16rpx;
  z-index: 1;
}

.avatar-icon {
  font-size: 32rpx;
}

/* ========== Bento 功能网格 ========== */

.bento-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-auto-rows: 120rpx;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.bento-card {
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.bento-card:active {
  transform: scale(0.97);
}

/* 绿色高卡 - 占2行 */
.card-green {
  grid-row: span 2;
  background: linear-gradient(145deg, #0a6847, #16a34a);
  box-shadow: 0 8rpx 24rpx rgba(10, 104, 71, 0.25);
}

.card-green .card-title,
.card-green .card-desc {
  color: #fff;
}

.card-green .card-desc {
  color: rgba(255, 255, 255, 0.65);
}

/* 白色小卡 */
.card-white {
  background: #fff;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.04), 0 8rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-white .card-title {
  color: #1a1a2e;
}

/* 深色宽卡 - 占2列 */
.card-dark {
  grid-column: span 2;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: #1a1a2e;
  box-shadow: 0 8rpx 24rpx rgba(26, 26, 46, 0.3);
}

.card-dark .card-title,
.card-dark .card-desc {
  color: #fff;
}

.card-dark .card-desc {
  color: rgba(255, 255, 255, 0.5);
}

/* 通用文字 */
.card-emoji {
  display: block;
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.card-desc {
  display: block;
  font-size: 20rpx;
}

/* 深色卡内部布局 */
.card-dark-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-dark-left .card-emoji {
  margin-bottom: 0;
}

.card-dark-text .card-title {
  margin-bottom: 0;
}

.card-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* ========== 今日推荐 ========== */

.section {
  margin-bottom: 8rpx;
}

.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 8rpx 16rpx;
}

.section-title-wrap {
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 6rpx;
}

.section-underline {
  width: 40rpx;
  height: 4rpx;
  background: #e94560;
  border-radius: 2rpx;
}

.section-refresh {
  font-size: 24rpx;
  font-weight: 500;
  color: #e94560;
}

/* 菜谱网格 */
.recipe-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-auto-rows: 200rpx;
  gap: 12rpx;
  padding: 0 4rpx;
}

.recipe-card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.04), 0 8rpx 20rpx rgba(0, 0, 0, 0.06);
}

.recipe-card:active {
  transform: scale(0.97);
}

/* 第一张高卡 */
.recipe-tall {
  grid-row: span 2;
}

/* 封面图区域 */
.recipe-cover {
  position: relative;
  flex: 1;
  background: #f5f5f7;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.recipe-img {
  width: 100rpx;
  height: 100rpx;
}

.recipe-tall .recipe-img {
  width: 140rpx;
  height: 140rpx;
}

/* 轻食角标 */
.recipe-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  font-size: 18rpx;
  color: #fff;
  background: #16a34a;
  padding: 3rpx 12rpx;
  border-radius: 100rpx;
}

/* 时间角标 */
.recipe-time {
  position: absolute;
  bottom: 8rpx;
  left: 8rpx;
  font-size: 18rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.55);
  padding: 3rpx 10rpx;
  border-radius: 8rpx;
}

/* 文字信息 */
.recipe-info {
  padding: 12rpx 16rpx 14rpx;
  display: flex;
  flex-direction: column;
}

.recipe-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-cal {
  font-size: 20rpx;
  color: #8a8f98;
}

/* ========== 骨架屏 ========== */

.skeleton-img {
  width: 100%;
  height: 140rpx;
  background: linear-gradient(90deg, #e8e8ec 25%, #f5f5f7 50%, #e8e8ec 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skeleton-text {
  width: 60%;
  height: 24rpx;
  margin: 12rpx 14rpx 0;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #e8e8ec 25%, #f5f5f7 50%, #e8e8ec 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ========== 空状态 ========== */

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #8a8f98;
}

/* ========== 底部留白 ========== */

.bottom-space {
  height: 120rpx;
}
