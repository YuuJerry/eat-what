/* 首页 — 「厨房笔记本」风格 */
/* 暖米白 · 深咖Hero · 赤陶点缀 · 交错布局 */

.page {
  background: #FAF6F1;
  min-height: 100vh;
}

/* ===== 深咖 Hero ===== */
.hero {
  background: #2D2A26;
  padding: 44rpx 32rpx 36rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.hero-greeting {
  font-size: 44rpx;
  font-weight: 700;
  color: #FAF6F1;
  display: block;
  letter-spacing: 2rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(250, 246, 241, 0.55);
  margin-top: 6rpx;
  display: block;
}

.hero-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: rgba(250, 246, 241, 0.10);
  border: 2rpx solid rgba(250, 246, 241, 0.20);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
}

/* 搜索条 — 嵌入 Hero */
.hero-search {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(250, 246, 241, 0.08);
  border: 2rpx solid rgba(250, 246, 241, 0.12);
  border-radius: 16rpx;
  padding: 18rpx 24rpx;
}

.search-icon {
  font-size: 26rpx;
  opacity: 0.5;
}

.search-text {
  font-size: 26rpx;
  color: rgba(250, 246, 241, 0.35);
}

/* ===== 功能入口 — 赤陶胶囊横排 ===== */
.pill-row {
  display: flex;
  gap: 14rpx;
  padding: 28rpx 24rpx 8rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.pill-row::-webkit-scrollbar {
  display: none;
}

.pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  background: #FFFFFF;
  border-radius: 100rpx;
  box-shadow:
    0 2rpx 6rpx rgba(139, 120, 90, 0.06),
    0 6rpx 16rpx rgba(139, 120, 90, 0.08);
  flex-shrink: 0;
}

.pill:active {
  transform: scale(0.95);
}

.pill-icon {
  font-size: 30rpx;
}

.pill-text {
  font-size: 24rpx;
  font-weight: 500;
  color: #2D2A26;
  white-space: nowrap;
}

/* ===== 区块标题 ===== */
.section {
  padding: 16rpx 0;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 32rpx 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2A26;
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 8rpx;
}

.refresh-btn {
  padding: 8rpx 0;
}

.refresh-text {
  font-size: 24rpx;
  color: #C85A36;
  font-weight: 500;
  border-bottom: 2rpx solid #C85A36;
  padding-bottom: 2rpx;
}

/* ===== 交错网格（关键布局） ===== */
.stagger-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
  grid-auto-flow: dense;
}

/* 卡片基础 */
.recipe-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow:
    0 2rpx 6rpx rgba(139, 120, 90, 0.06),
    0 8rpx 20rpx rgba(139, 120, 90, 0.08);
}

.recipe-card:active {
  transform: scale(0.97);
}

/* 交错高度 — 第1、4、7...张卡高一点 */
.recipe-card.tall .card-media {
  height: 260rpx;
}

.recipe-card:not(.tall) .card-media {
  height: 200rpx;
}

/* 卡片封面 */
.card-media {
  position: relative;
  width: 100%;
  background: #F5EDE4;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.card-img {
  width: 120rpx;
  height: 120rpx;
  transition: transform 0.3s ease;
}

.recipe-card:active .card-img {
  transform: scale(1.05);
}

/* 角标 */
.card-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: #6B8F71;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

/* 卡片内容 */
.card-body {
  padding: 16rpx 20rpx 20rpx;
}

.card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D2A26;
  display: block;
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-meta {
  font-size: 22rpx;
  color: #8A8279;
  display: block;
}

/* ===== 骨架屏 ===== */
.skel-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(139, 120, 90, 0.06);
}

.skel-card.tall .skel-img {
  height: 260rpx;
}

.skel-img {
  width: 100%;
  height: 200rpx;
  background: linear-gradient(90deg, #F0E8DE 25%, #FAF6F1 50%, #F0E8DE 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skel-line {
  height: 24rpx;
  margin: 14rpx 18rpx 0;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #F0E8DE 25%, #FAF6F1 50%, #F0E8DE 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skel-line.short {
  width: 55%;
  margin-bottom: 18rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== 底部留白 ===== */
.bottom-spacer {
  height: 120rpx;
}
