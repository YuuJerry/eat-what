/* 首页 — Bento Grid 模块化布局 */
/* 苹果风格：不等高卡片 + 深浅混搭 + 视觉层次 */

.page {
  background: #F5F5F7;
  min-height: 100vh;
  padding: 0 16rpx;
}

/* ===== Hero 全宽卡 ===== */
.bento-hero {
  position: relative;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  border-radius: 28rpx;
  padding: 40rpx 28rpx 36rpx;
  margin: 16rpx 0 20rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-bg {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
}

.hero-content {
  flex: 1;
  z-index: 1;
}

.hero-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.45);
  display: block;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  margin-bottom: 6rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  display: block;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.hero-search {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 14rpx;
  padding: 14rpx 20rpx;
}

.hero-search-icon {
  font-size: 24rpx;
  opacity: 0.4;
}

.hero-search-txt {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.30);
}

.hero-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.10);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
  z-index: 1;
}

/* ===== Bento 功能网格 — 2列不等高 ===== */
.bento-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-auto-rows: 120rpx;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.bento-card {
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.bento-card:active {
  transform: scale(0.97);
}

/* 高卡（占2行） */
.bento-tall {
  grid-row: span 2;
}

/* 宽卡（占2列） */
.bento-wide {
  grid-column: span 2;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

/* 深绿卡 */
.bento-green {
  background: linear-gradient(145deg, #0a6847, #16a34a);
  box-shadow: 0 8rpx 24rpx rgba(10, 104, 71, 0.25);
}

.bento-green .bento-title,
.bento-green .bento-desc {
  color: #fff;
}

.bento-green .bento-desc {
  color: rgba(255, 255, 255, 0.65);
}

/* 奶油卡 */
.bento-cream {
  background: #ffffff;
  box-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.04),
    0 8rpx 20rpx rgba(0, 0, 0, 0.06);
}

.bento-cream .bento-title {
  color: #1a1a2e;
}

/* 深色卡 */
.bento-dark {
  background: #1a1a2e;
  box-shadow: 0 8rpx 24rpx rgba(26, 26, 46, 0.3);
}

.bento-dark .bento-title,
.bento-dark .bento-desc {
  color: #fff;
}

.bento-dark .bento-desc {
  color: rgba(255, 255, 255, 0.50);
}

.bento-emoji {
  font-size: 40rpx;
  margin-bottom: 10rpx;
  display: block;
}

.bento-title {
  font-size: 26rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 4rpx;
}

.bento-desc {
  font-size: 20rpx;
  display: block;
}

.bento-wide-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.bento-wide-left .bento-emoji {
  margin-bottom: 0;
}

.bento-wide-left .bento-title {
  margin-bottom: 0;
}

.bento-wide-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.40);
}

/* ===== 区块标题 ===== */
.section {
  margin-bottom: 8rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 8rpx 16rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 6rpx;
}

.section-line {
  width: 40rpx;
  height: 4rpx;
  background: #e94560;
  border-radius: 2rpx;
}

.section-link {
  font-size: 24rpx;
  color: #e94560;
  font-weight: 500;
}

/* ===== Bento 菜谱网格 — 不等高 ===== */
.bento-recipe-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  grid-auto-rows: 200rpx;
  gap: 12rpx;
  padding: 0 4rpx;
}

.bento-recipe {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow:
    0 2rpx 4rpx rgba(0, 0, 0, 0.04),
    0 8rpx 20rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
}

.bento-recipe:active {
  transform: scale(0.97);
}

/* 第一张卡：高卡（占2行） */
.bento-recipe.tall {
  grid-row: span 2;
}

/* 第四张卡：宽卡（占2列） */
.bento-recipe.wide {
  grid-column: span 2;
  flex-direction: row;
}

.bento-recipe.wide .br-media {
  width: 45%;
  height: 100%;
}

.bento-recipe.wide .br-body {
  flex: 1;
  justify-content: center;
}

/* 封面图 */
.br-media {
  position: relative;
  width: 100%;
  flex: 1;
  background: #F5F5F7;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.br-img {
  width: 100rpx;
  height: 100rpx;
}

.bento-recipe.tall .br-img {
  width: 140rpx;
  height: 140rpx;
}

/* 角标 */
.br-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background: #16a34a;
  color: #fff;
  font-size: 18rpx;
  padding: 3rpx 12rpx;
  border-radius: 100rpx;
}

.br-time {
  position: absolute;
  bottom: 8rpx;
  left: 8rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 18rpx;
  padding: 3rpx 10rpx;
  border-radius: 8rpx;
}

/* 内容区 */
.br-body {
  padding: 12rpx 16rpx 14rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.br-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.br-cal {
  font-size: 20rpx;
  color: #8a8f98;
  display: block;
}

/* ===== 骨架屏 ===== */
.bento-recipe.tall .skel-img {
  height: 100%;
}

.skel-img {
  width: 100%;
  height: 140rpx;
  background: linear-gradient(90deg, #e8e8ec 25%, #f5f5f7 50%, #e8e8ec 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skel-txt {
  height: 24rpx;
  margin: 12rpx 14rpx 0;
  border-radius: 8rpx;
  width: 60%;
  background: linear-gradient(90deg, #e8e8ec 25%, #f5f5f7 50%, #e8e8ec 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== 底部留白 ===== */
.bottom-spacer {
  height: 120rpx;
}
