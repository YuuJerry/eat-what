/* 首页 — 暖陶土 Claymorphism */

.container {
  padding: 24rpx 0 120rpx;
}

/* 顶部问候 */
.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx 32rpx;
}

.hero-greeting {
  font-size: 40rpx;
  font-weight: 700;
  color: #3D2C1E;
  display: block;
}

.hero-sub {
  font-size: 26rpx;
  color: #8B7355;
  margin-top: 4rpx;
  display: block;
}

.hero-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border: 2rpx solid #D97706;
}

/* 快捷入口网格 */
.actions-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 0 24rpx 32rpx;
}

.action-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 8rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  border: 2rpx solid #F2E6E2;
  box-shadow:
    0 4rpx 8rpx rgba(154, 52, 18, 0.04),
    0 8rpx 16rpx rgba(154, 52, 18, 0.06);
}

.action-card:active {
  transform: scale(0.95);
}

.action-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.action-title {
  font-size: 22rpx;
  color: #3D2C1E;
  font-weight: 500;
}

/* 区块 */
.section {
  padding: 0 0 16rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D2C1E;
}

.section-hint {
  font-size: 22rpx;
  color: #8B7355;
}

/* 骨架屏 */
.loading {
  padding: 0 24rpx;
}

.loading-skeleton {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.skeleton-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  background: linear-gradient(90deg, #F2E6E2 25%, #FEF3C7 50%, #F2E6E2 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.skeleton-text {
  flex: 1;
  height: 40rpx;
  border-radius: 12rpx;
  background: linear-gradient(90deg, #F2E6E2 25%, #FEF3C7 50%, #F2E6E2 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  margin-top: 20rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 菜谱卡片网格 */
.recipe-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
}

.recipe-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  border: 2rpx solid #F2E6E2;
  box-shadow:
    0 4rpx 8rpx rgba(154, 52, 18, 0.04),
    0 8rpx 16rpx rgba(154, 52, 18, 0.06);
}

.recipe-card:active {
  transform: scale(0.97);
}

.recipe-cover {
  position: relative;
  width: 100%;
  height: 200rpx;
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-img {
  width: 120rpx;
  height: 120rpx;
}

.recipe-badge {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: linear-gradient(135deg, #059669, #10B981);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-weight: 600;
}

.recipe-info {
  padding: 16rpx 20rpx 20rpx;
}

.recipe-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2C1E;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recipe-meta {
  display: flex;
  gap: 16rpx;
  font-size: 22rpx;
  color: #8B7355;
}
