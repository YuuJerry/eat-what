<!-- 首页 -->
<view class="page">

  <!-- Hero 区 -->
  <view class="hero" bindtap="onGoSearch">
    <view class="hero-content">
      <text class="hero-greeting">{{greeting}}</text>
      <text class="hero-title">今天想吃什么？</text>
      <view class="hero-search" bindtap="onGoSearch">
        <text class="search-icon">🔍</text>
        <text class="search-placeholder">搜索菜谱或食材</text>
      </view>
    </view>
    <view class="hero-avatar" bindtap="onGoProfile">
      <text class="avatar-icon">👤</text>
    </view>
  </view>

  <!-- Bento 功能区 -->
  <view class="bento-grid">
    <view class="bento-card card-green" bindtap="onQuickAction" data-url="/pages/fridge/fridge">
      <text class="card-emoji">🧊</text>
      <text class="card-title">冰箱推荐</text>
      <text class="card-desc">看看有什么能做</text>
    </view>

    <view class="bento-card card-white" bindtap="onQuickAction" data-url="/pages/diet/diet">
      <text class="card-emoji">🥗</text>
      <text class="card-title">减脂餐</text>
    </view>

    <view class="bento-card card-white" bindtap="onQuickAction" data-url="/pages/vote/room">
      <text class="card-emoji">🗳️</text>
      <text class="card-title">投票</text>
    </view>

    <view class="bento-card card-dark" bindtap="onQuickAction" data-url="/pages/index/index">
      <view class="card-dark-left">
        <text class="card-emoji">🎲</text>
        <view class="card-dark-text">
          <text class="card-title">随机转盘</text>
          <text class="card-desc">帮你决定吃什么</text>
        </view>
      </view>
      <text class="card-arrow">→</text>
    </view>
  </view>

  <!-- 今日推荐 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title-wrap">
        <text class="section-title">今日推荐</text>
        <view class="section-underline"></view>
      </view>
      <text class="section-refresh" bindtap="onRefresh">换一批</text>
    </view>

    <!-- 骨架屏 -->
    <view wx:if="{{isLoading}}" class="recipe-grid">
      <view class="recipe-card" wx:for="{{[1,2,3,4]}}" wx:key="*this">
        <view class="skeleton-img"></view>
        <view class="skeleton-text"></view>
      </view>
    </view>

    <!-- 菜谱网格 -->
    <view class="recipe-grid" wx:if="{{!isLoading && recommendList.length > 0}}">
      <view
        class="recipe-card {{index === 0 ? 'recipe-tall' : ''}}"
        wx:for="{{recommendList}}"
        wx:key="name"
        bindtap="onRecipeTap"
        data-index="{{index}}"
      >
        <view class="recipe-cover">
          <image src="{{item.coverIcon}}" mode="aspectFit" class="recipe-img" />
          <view class="recipe-badge" wx:if="{{item.isDietFriendly}}">轻食</view>
          <view class="recipe-time">{{item.cookTime}}min</view>
        </view>
        <view class="recipe-info">
          <text class="recipe-name">{{item.name}}</text>
          <text class="recipe-cal" wx:if="{{item.calories}}">{{item.calories}}kcal</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{!isLoading && recommendList.length === 0}}">
      <text class="empty-icon">🍽️</text>
      <text class="empty-text">下拉刷新获取推荐</text>
    </view>
  </view>

  <view class="bottom-space"></view>
</view>
