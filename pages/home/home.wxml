<!-- 首页容器 -->
<view class="container">
  <!-- Banner 区域：展示应用标题和副标题 -->
  <view class="banner">
    <view class="banner-content">
      <text class="banner-emoji">🍽️</text>
      <view class="banner-text">
        <text class="banner-title">今天吃什么</text>
        <text class="banner-desc">智能帮你决定每一餐</text>
      </view>
    </view>
  </view>

  <!-- 快捷入口区域：展示四个功能快捷操作按钮 -->
  <view class="section">
    <text class="section-title">快捷操作</text>
    <view class="quick-actions">
      <!-- 遍历 quickActions 数组，渲染每个快捷入口 -->
      <view
        class="quick-action-item"
        wx:for="{{quickActions}}"
        wx:key="title"
        bindtap="onQuickAction"
        data-url="{{item.url}}"
      >
        <view class="quick-action-icon">
          <text>{{item.icon}}</text>
        </view>
        <text class="quick-action-title">{{item.title}}</text>
        <text class="quick-action-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 智能推荐区域：根据是否个性化显示不同标题 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">🤖 AI 推荐</text>
    </view>

    <!-- 加载状态：数据加载中时显示提示文字 -->
    <view class="loading" wx:if="{{isLoading}}">
      <text class="loading-text">正在为你挑选美食...</text>
    </view>

    <!-- 推荐列表：加载完成后展示菜谱卡片列表 -->
    <view class="recommend-list" wx:if="{{!isLoading && recommendList.length > 0}}">
      <!-- 单个菜谱卡片，点击跳转到详情页 -->
      <view
        class="recipe-card"
        wx:for="{{recommendList}}"
        wx:key="name"
        bindtap="onRecipeTap"
        data-index="{{index}}"
      >
        <!-- 菜谱封面：手绘图标 -->
        <view class="recipe-cover hand-drawn-placeholder">
          <image src="{{item.coverIcon}}" mode="aspectFit" class="cover-icon-img" />
        </view>
        <!-- 菜谱信息区域：名称、烹饪时间、卡路里、标签 -->
        <view class="recipe-info">
          <text class="recipe-name">{{item.name}}</text>
          <view class="recipe-meta">
            <text class="recipe-time">⏱ {{item.cookTime}}分钟</text>
            <text class="recipe-cal" wx:if="{{item.calories}}">🔥 {{item.calories}}kcal</text>
          </view>
          <!-- 菜谱标签：最多显示 2 个标签，减脂友好标红 -->
          <view class="recipe-tags">
            <text class="tag {{item.isDietFriendly ? 'tag-active' : ''}}" wx:if="{{item.isDietFriendly}}">减脂</text>
            <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" wx:if="{{index < 2}}">{{tag}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态：无推荐数据时显示提示 -->
    <view class="empty-state" wx:if="{{!isLoading && recommendList.length === 0}}">
      <text class="empty-emoji">🤔</text>
      <text class="empty-text">暂无推荐，去菜谱页面逛逛吧</text>
    </view>
  </view>
</view>
