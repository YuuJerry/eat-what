<!-- 首页 — 「厨房笔记本」风格 -->
<view class="page">

  <!-- ===== 深咖 Hero — 时间感知 ===== -->
  <view class="hero">
    <view class="hero-top">
      <view>
        <text class="hero-greeting">{{greeting}}</text>
        <text class="hero-sub">今天想吃点什么？</text>
      </view>
      <view class="hero-avatar" bindtap="onGoProfile">
        <text>👤</text>
      </view>
    </view>
    <!-- 搜索入口 -->
    <view class="hero-search" bindtap="onGoSearch">
      <text class="search-icon">🔍</text>
      <text class="search-text">搜索菜谱或食材...</text>
    </view>
  </view>

  <!-- ===== 功能入口 — 赤陶色胶囊横排 ===== -->
  <view class="pill-row">
    <view class="pill" bindtap="onQuickAction" data-url="/pages/fridge/fridge">
      <text class="pill-icon">🧊</text>
      <text class="pill-text">冰箱推荐</text>
    </view>
    <view class="pill" bindtap="onQuickAction" data-url="/pages/diet/diet">
      <text class="pill-icon">🥗</text>
      <text class="pill-text">减脂餐</text>
    </view>
    <view class="pill" bindtap="onQuickAction" data-url="/pages/vote/room">
      <text class="pill-icon">🗳️</text>
      <text class="pill-text">投票</text>
    </view>
    <view class="pill" bindtap="onQuickAction" data-url="/pages/index/index">
      <text class="pill-icon">🎲</text>
      <text class="pill-text">转盘</text>
    </view>
  </view>

  <!-- ===== 今日推荐 — 交错网格 ===== -->
  <view class="section">
    <view class="section-head">
      <view>
        <text class="section-title">今日推荐</text>
        <view class="accent-line"></view>
      </view>
      <view class="refresh-btn" bindtap="onRefresh">
        <text class="refresh-text">换一批</text>
      </view>
    </view>

    <!-- 骨架屏 -->
    <view wx:if="{{isLoading}}" class="stagger-grid">
      <view class="skel-card tall" wx:for="{{[1,2,3,4]}}" wx:key="*this">
        <view class="skel-img"></view>
        <view class="skel-line"></view>
        <view class="skel-line short"></view>
      </view>
    </view>

    <!-- 交错卡片网格 -->
    <view class="stagger-grid" wx:if="{{!isLoading && recommendList.length > 0}}">
      <view
        class="recipe-card {{index % 3 === 0 ? 'tall' : ''}}"
        wx:for="{{recommendList}}"
        wx:key="name"
        bindtap="onRecipeTap"
        data-index="{{index}}"
      >
        <view class="card-media">
          <image src="{{item.coverIcon}}" mode="aspectFit" class="card-img" />
          <view class="card-badge" wx:if="{{item.isDietFriendly}}">轻食</view>
        </view>
        <view class="card-body">
          <text class="card-name">{{item.name}}</text>
          <text class="card-meta">{{item.cookTime}}分钟 · {{item.calories}}kcal</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!isLoading && recommendList.length === 0}}">
      <text class="empty-emoji">🍽️</text>
      <text class="empty-text">下拉刷新获取推荐</text>
    </view>
  </view>

  <view class="bottom-spacer"></view>
</view>
