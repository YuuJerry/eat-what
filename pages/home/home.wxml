<!-- 首页 — 星巴克设计语言 -->
<view class="container">

  <!-- Hero 区 — 深绿背景（星巴克特征） -->
  <view class="hero">
    <view class="hero-content">
      <text class="hero-title">今天吃什么</text>
      <text class="hero-sub">帮你决定每一餐</text>
    </view>
    <view class="hero-avatar" bindtap="onGoProfile">
      <text>👤</text>
    </view>
  </view>

  <!-- 快捷入口 — 胶囊按钮风格 -->
  <view class="actions-row">
    <view
      class="action-pill"
      wx:for="{{quickActions}}"
      wx:key="title"
      bindtap="onQuickAction"
      data-url="{{item.url}}"
    >
      <text class="action-icon">{{item.icon}}</text>
      <text class="action-label">{{item.title}}</text>
    </view>
  </view>

  <!-- 今日推荐 — 产品卡片风格 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">今日推荐</text>
      <text class="section-link" bindtap="onRefresh">换一批</text>
    </view>

    <!-- 骨架屏 -->
    <view wx:if="{{isLoading}}" class="skeleton-grid">
      <view class="skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="*this">
        <view class="skeleton-img"></view>
        <view class="skeleton-line"></view>
        <view class="skeleton-line short"></view>
      </view>
    </view>

    <!-- 菜谱卡片网格 -->
    <view class="recipe-grid" wx:if="{{!isLoading && recommendList.length > 0}}">
      <view
        class="recipe-card"
        wx:for="{{recommendList}}"
        wx:key="name"
        bindtap="onRecipeTap"
        data-index="{{index}}"
      >
        <view class="recipe-img">
          <image src="{{item.coverIcon}}" mode="aspectFit" class="cover-img" />
          <view class="diet-tag" wx:if="{{item.isDietFriendly}}">轻食</view>
        </view>
        <view class="recipe-body">
          <text class="recipe-name">{{item.name}}</text>
          <text class="recipe-meta">{{item.cookTime}}分钟 · {{item.calories}}kcal</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!isLoading && recommendList.length === 0}}">
      <text class="empty-emoji">🍽️</text>
      <text class="empty-text">下拉刷新获取推荐</text>
    </view>
  </view>

</view>
