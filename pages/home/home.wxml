<!-- 首页 -->
<view class="container">
  <!-- 顶部问候 -->
  <view class="hero">
    <view class="hero-left">
      <text class="hero-greeting">🍽️ 今天吃什么</text>
      <text class="hero-sub">帮你决定每一餐</text>
    </view>
    <view class="hero-avatar" bindtap="onGoProfile">
      <text>👤</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="actions-grid">
    <view
      class="action-card"
      wx:for="{{quickActions}}"
      wx:key="title"
      bindtap="onQuickAction"
      data-url="{{item.url}}"
    >
      <text class="action-icon">{{item.icon}}</text>
      <text class="action-title">{{item.title}}</text>
    </view>
  </view>

  <!-- 热门推荐 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">🔥 今日推荐</text>
      <text class="section-hint">每天换一批</text>
    </view>

    <view class="loading" wx:if="{{isLoading}}">
      <view class="loading-skeleton" wx:for="{{[1,2,3,4]}}" wx:key="*this">
        <view class="skeleton-img"></view>
        <view class="skeleton-text"></view>
      </view>
    </view>

    <view class="recipe-grid" wx:if="{{!isLoading && recommendList.length > 0}}">
      <view
        class="recipe-card"
        wx:for="{{recommendList}}"
        wx:key="name"
        bindtap="onRecipeTap"
        data-index="{{index}}"
      >
        <view class="recipe-cover">
          <image src="{{item.coverIcon}}" mode="aspectFit" class="cover-img" />
          <view class="recipe-badge" wx:if="{{item.isDietFriendly}}">减脂</view>
        </view>
        <view class="recipe-info">
          <text class="recipe-name">{{item.name}}</text>
          <view class="recipe-meta">
            <text>⏱ {{item.cookTime}}分</text>
            <text wx:if="{{item.calories}}">🔥 {{item.calories}}kcal</text>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{!isLoading && recommendList.length === 0}}">
      <text class="empty-emoji">🤔</text>
      <text class="empty-text">暂无推荐，下拉刷新试试</text>
    </view>
  </view>
</view>
