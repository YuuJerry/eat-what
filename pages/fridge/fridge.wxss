/* 冰箱推荐页 — 严格按设计稿重写 */

/* ==================== 页面基础 ==================== */
.page {
  background: #F5F5F5;
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ==================== 深色头部区 ==================== */
.header-dark {
  background: #1A1A2E;
  padding: 28rpx 28rpx 0;
}

/* ==================== 已选食材区 ==================== */
.selected-section {
  padding-bottom: 24rpx;
}

.selected-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.selected-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.selected-clear {
  font-size: 24rpx;
  color: #E94560;
  font-weight: 600;
  padding: 4rpx 0;
}

.selected-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.sel-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #E94560;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 500;
  padding: 10rpx 22rpx;
  border-radius: 100rpx;
  line-height: 1;
}

.sel-tag-x {
  font-size: 20rpx;
  opacity: 0.8;
  margin-left: 4rpx;
}

/* ==================== 搜索条 ==================== */
.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 20rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #FFFFFF;
  background: transparent;
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.4);
}

/* ==================== 分类标签 ==================== */
.cat-scroll {
  padding: 0 0 24rpx;
  white-space: nowrap;
}

.cat-pill {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 100rpx;
  background: rgba(255, 255, 255, 0.12);
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
  line-height: 1;
}

.cat-pill.active {
  background: #E94560;
  color: #FFFFFF;
}

/* ==================== 白色内容区 ==================== */
.content-white {
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  margin-top: -8rpx;
  position: relative;
  z-index: 1;
}

/* ==================== 食材网格 ==================== */
.ing-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 24rpx 28rpx 16rpx;
}

.ing-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0 12rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 2rpx solid #F0F0F0;
  position: relative;
  transition: all 0.2s;
}

.ing-item:active {
  transform: scale(0.95);
}

.ing-item.selected {
  border-color: #E94560;
  background: #FFF5F7;
}

.ing-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #E94560;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  color: #FFFFFF;
  font-size: 18rpx;
  font-weight: 700;
}

.ing-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.ing-img {
  width: 100%;
  height: 100%;
}

.ing-name {
  font-size: 20rpx;
  color: #333333;
  text-align: center;
  line-height: 1.3;
}

/* ==================== 推荐按钮 ==================== */
.actions {
  padding: 8rpx 28rpx 32rpx;
}

.action-btn {
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

.recommend-btn {
  background: #E94560;
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(233, 69, 96, 0.3);
}

.recommend-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* ==================== 推荐结果区 ==================== */
.results {
  padding: 28rpx;
}

.results-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.results-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.results-count {
  font-size: 24rpx;
  color: #999999;
}

/* 结果卡片 */
.result-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.result-card.can-cook {
  border-left: 8rpx solid #4ECDC4;
}

/* 卡片头部 */
.result-top {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.result-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  background: #FFF5F7;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.rc-img {
  width: 72rpx;
  height: 72rpx;
}

.result-info {
  flex: 1;
  min-width: 0;
}

.result-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A2E;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.result-meta {
  display: flex;
  gap: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: #999999;
}

.meta-icon {
  font-size: 22rpx;
}

.result-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.fav-btn {
  font-size: 36rpx;
  padding: 4rpx;
}

/* 匹配率徽章 */
.match-badge {
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  white-space: nowrap;
}

.match-badge.perfect {
  background: #E8F8F5;
  color: #00B894;
}

.match-badge.partial {
  background: #FFF8E1;
  color: #FDCB6E;
}

/* 用料标签 */
.result-ings {
  margin-bottom: 16rpx;
}

.sub-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  margin-bottom: 12rpx;
}

.ing-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.ing-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #F5F5F5;
  padding: 8rpx 18rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #666666;
}

.ing-amount {
  color: #999999;
  font-size: 20rpx;
}

/* 缺少食材 */
.missing-section {
  display: flex;
  align-items: flex-start;
  gap: 6rpx;
  padding: 14rpx 18rpx;
  background: #FFF8E1;
  border-radius: 14rpx;
  margin-bottom: 16rpx;
}

.missing-icon {
  font-size: 22rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.missing-label {
  font-size: 22rpx;
  color: #E17055;
  font-weight: 600;
  flex-shrink: 0;
}

.missing-items {
  font-size: 22rpx;
  color: #B2BEC3;
  line-height: 1.5;
}

/* 步骤 */
.steps-section {
  border-top: 1rpx solid #F0F0F0;
  padding-top: 16rpx;
}

.steps-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 0;
  font-size: 24rpx;
  color: #E94560;
  font-weight: 500;
}

.toggle-icon {
  font-size: 20rpx;
}

.steps-content {
  margin-top: 16rpx;
}

.step-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.step-num-wrap {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #E94560;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.step-num {
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 700;
}

.step-txt {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
  line-height: 1.7;
}

/* 视频 */
.video-section {
  border-top: 1rpx solid #F0F0F0;
  padding-top: 16rpx;
}

.video-card {
  display: flex;
  gap: 16rpx;
  background: #F9F9F9;
  border-radius: 16rpx;
  padding: 16rpx;
}

.video-card:active {
  background: #F0F0F0;
}

.vid-thumb {
  position: relative;
  width: 180rpx;
  height: 112rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #E0E0E0;
}

.vid-img {
  width: 100%;
  height: 100%;
}

.vid-play {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-icon {
  color: #FFFFFF;
  font-size: 20rpx;
  margin-left: 2rpx;
}

.vid-dur {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  background: rgba(0, 0, 0, 0.65);
  color: #FFFFFF;
  font-size: 16rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.vid-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.vid-title {
  font-size: 24rpx;
  color: #333333;
  font-weight: 600;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 6rpx;
  line-height: 1.4;
}

.vid-sub {
  font-size: 20rpx;
  color: #999999;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999999;
}

/* ==================== 购物清单弹窗 ==================== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx;
  width: 620rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.modal-body {
  max-height: 50vh;
  margin-bottom: 24rpx;
}

.modal-text {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.8;
  white-space: pre-wrap;
}

.modal-btns {
  display: flex;
  gap: 16rpx;
}

.modal-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

.modal-btn.cancel {
  background: #F5F5F5;
  color: #666666;
}

.modal-btn.confirm {
  background: #E94560;
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(233, 69, 96, 0.25);
}

.modal-btn:active {
  transform: scale(0.97);
}
