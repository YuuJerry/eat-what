/* 页面容器 */
.container {
  padding: 20rpx 24rpx 40rpx;
}

/* ===== 已选食材区域 ===== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.clear-btn {
  font-size: 26rpx;
  color: #FF6B6B;
}

.selected-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.selected-tag {
  background: #FF6B6B;
  color: #fff;
  font-size: 26rpx;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
}

.placeholder-text {
  font-size: 26rpx;
  color: #ccc;
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  margin: 20rpx 0;
  background: #fff;
  border-radius: 50rpx;
  padding: 4rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 72rpx;
}

/* ===== 分类标签 ===== */
.category-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.category-tab {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 40rpx;
  background: #fff;
  border: 2rpx solid #eee;
  font-size: 26rpx;
  color: #666;
}

.category-tab.active {
  background: #4ECDC4;
  color: #fff;
  border-color: #4ECDC4;
}

/* ===== 食材网格 ===== */
.ingredient-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.ingredient-item {
  width: calc(25% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: relative;
  box-sizing: border-box;
}

.ingredient-item.selected {
  background: #E8F8F5;
  box-shadow: 0 2rpx 8rpx rgba(78, 205, 196, 0.2);
}

/* 手绘图标容器 */
.ingredient-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ingredient-img {
  width: 56rpx;
  height: 56rpx;
}

.ingredient-name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

/* 选中标记 */
.check-mark {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #4ECDC4;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

/* ===== 确定按钮 ===== */
.search-action {
  margin: 20rpx 0;
}

.search-recipes-btn {
  text-align: center;
}

/* ===== 推荐结果 ===== */
.results-section {
  margin-top: 30rpx;
}

.searching-hint {
  font-size: 24rpx;
  color: #999;
}

.result-card {
  margin-left: 0;
  margin-right: 0;
  transition: all 0.3s;
}

/* 100% 匹配 = 绿色边框 */
.result-card.can-cook {
  border-left: 8rpx solid #4ECDC4;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.2);
}

/* 差1种 = 金色边框 */
.result-card.almost {
  border-left: 8rpx solid #FFB300;
  box-shadow: 0 4rpx 16rpx rgba(255, 179, 0, 0.15);
}

.result-header {
  display: flex;
  align-items: center;
}

.result-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  overflow: hidden;
  background: #FFF5F5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-img {
  width: 80rpx;
  height: 80rpx;
}

.result-info {
  flex: 1;
  margin-left: 16rpx;
}

.result-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.result-meta {
  display: flex;
  gap: 16rpx;
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 匹配度徽章 */
.match-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

/* 部分匹配 = 绿色 */
.match-badge.partial {
  background: #E8F8F5;
}

.match-badge.partial .match-rate,
.match-badge.partial .match-label {
  color: #4ECDC4;
}

/* 完美匹配 = 金色 */
.match-badge.perfect {
  background: #FFF8E1;
}

.match-badge.perfect .match-rate,
.match-badge.perfect .match-label {
  color: #FF8F00;
}

.match-rate {
  font-size: 32rpx;
  font-weight: bold;
}

.match-label {
  font-size: 20rpx;
}

/* 结果详情 */
.result-detail {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.owned-text {
  font-size: 24rpx;
  color: #4ECDC4;
}

.missing-list {
  margin-top: 8rpx;
}

.missing-label {
  font-size: 24rpx;
  color: #999;
}

.missing-items {
  font-size: 24rpx;
  color: #FF6B6B;
}

/* 只差一步提示 */
.almost-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #FF8F00;
  font-weight: bold;
}

/* 空状态 */
.empty-hint {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 8rpx;
}
