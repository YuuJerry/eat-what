/* 页面容器 */
.container {
  padding: 20rpx 24rpx 40rpx;
}

/* ===== 已选食材区域 ===== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.clear-btn {
  font-size: 26rpx;
  color: #FF6B6B;
}

.selected-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.selected-tag {
  background: #FF6B6B;
  color: #fff;
  font-size: 26rpx;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
}

.placeholder-text {
  font-size: 26rpx;
  color: #ccc;
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  margin: 20rpx 0;
  background: #fff;
  border-radius: 50rpx;
  padding: 4rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: 72rpx;
}

/* ===== 分类标签 ===== */
.category-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.category-tab {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 40rpx;
  background: #fff;
  border: 2rpx solid #eee;
  font-size: 26rpx;
  color: #666;
}

.category-tab.active {
  background: #4ECDC4;
  color: #fff;
  border-color: #4ECDC4;
}

/* ===== 食材网格 ===== */
.ingredient-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.ingredient-item {
  width: calc(25% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  position: relative;
  box-sizing: border-box;
}

.ingredient-item.selected {
  background: #E8F8F5;
  box-shadow: 0 2rpx 8rpx rgba(78, 205, 196, 0.2);
}

.ingredient-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ingredient-img {
  width: 56rpx;
  height: 56rpx;
}

.ingredient-name {
  font-size: 24rpx;
  color: #333;
  text-align: center;
}

.check-mark {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #4ECDC4;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

/* ===== 操作按钮区 ===== */
.action-buttons {
  display: flex;
  gap: 16rpx;
  margin: 20rpx 0;
}

.btn-ai {
  flex: 1;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  padding: 22rpx 0;
  border-radius: 50rpx;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
}

.btn-shopping {
  background: #fff;
  border: 2rpx solid #4ECDC4;
  color: #4ECDC4;
  font-size: 26rpx;
  font-weight: bold;
  padding: 20rpx 30rpx;
  border-radius: 50rpx;
  text-align: center;
}

/* ===== 推荐结果 ===== */
.results-section {
  margin-top: 20rpx;
}

.result-card {
  margin-left: 0;
  margin-right: 0;
  transition: all 0.3s;
}

/* 能做 = 绿色边框 */
.result-card.can-cook {
  border-left: 8rpx solid #4ECDC4;
  box-shadow: 0 4rpx 16rpx rgba(78, 205, 196, 0.2);
}

/* 差1种 = 金色边框 */
.result-card.almost {
  border-left: 8rpx solid #FFB300;
  box-shadow: 0 4rpx 16rpx rgba(255, 179, 0, 0.15);
}

.result-header {
  display: flex;
  align-items: center;
}

.result-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  overflow: hidden;
  background: #FFF5F5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-img {
  width: 80rpx;
  height: 80rpx;
}

.result-info {
  flex: 1;
  margin-left: 16rpx;
}

.result-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.result-meta {
  display: flex;
  gap: 16rpx;
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.match-badge {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}

.match-badge.partial {
  background: #E8F8F5;
  color: #4ECDC4;
}

.match-badge.perfect {
  background: #FFF8E1;
  color: #FF8F00;
}

.match-label {
  font-size: 24rpx;
  font-weight: bold;
}

/* 用料清单 */
.ingredients-list {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.sub-title {
  font-size: 24rpx;
  color: #666;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.ingredient-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.ing-tag {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
}

/* 缺少食材 */
.missing-section {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.missing-label {
  font-size: 24rpx;
  color: #999;
}

.missing-items {
  font-size: 24rpx;
  color: #FF6B6B;
}

.almost-hint {
  font-size: 24rpx;
  color: #FF8F00;
  font-weight: bold;
}

/* 步骤预览 */
.steps-section {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.steps-toggle {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
  padding: 8rpx 0;
}

.steps-content {
  margin-top: 12rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.step-num {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #667eea;
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 12rpx;
  margin-top: 4rpx;
}

.step-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

/* 空状态 */
.empty-hint {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 8rpx;
}

/* ===== 购物清单弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  width: 620rpx;
  max-height: 80vh;
}

.modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
  text-align: center;
}

.shopping-content {
  max-height: 500rpx;
  margin-bottom: 24rpx;
}

.shopping-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: #4ECDC4;
  color: #fff;
}
