/* 冰箱推荐 — 统一设计系统 */

.page { background: #F8F9FA; min-height: 100vh; padding-bottom: 40rpx; }

/* 已选食材区 */
.selected-bar { background: #fff; padding: 20rpx 24rpx; margin-bottom: 12rpx; }
.selected-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.selected-title { font-size: 28rpx; font-weight: 600; color: #2D3436; }
.selected-clear { font-size: 24rpx; color: #E94560; }
.selected-tags { display: flex; flex-wrap: wrap; gap: 10rpx; }
.sel-tag {
  background: rgba(233,69,96,0.08); color: #E94560; font-size: 24rpx;
  padding: 8rpx 18rpx; border-radius: 100rpx; font-weight: 500;
}

/* 搜索条 */
.search-row { padding: 12rpx 24rpx; }
.search-bar {
  display: flex; align-items: center; gap: 10rpx;
  background: #1A1A2E; border-radius: 16rpx; padding: 16rpx 20rpx;
}
.search-icon { font-size: 26rpx; opacity: 0.5; }
.search-input { flex: 1; font-size: 26rpx; color: #fff; background: transparent; }
.search-input::placeholder { color: rgba(255,255,255,0.35); }

/* 分类标签 */
.cat-scroll { padding: 8rpx 24rpx 12rpx; white-space: nowrap; }
.cat-pill {
  display: inline-flex; padding: 10rpx 24rpx; margin-right: 12rpx;
  border-radius: 100rpx; background: #fff; border: 2rpx solid #DFE6E9;
  font-size: 24rpx; color: #636E72; font-weight: 500;
}
.cat-pill.active { background: #E94560; border-color: #E94560; color: #fff; }

/* 食材网格 */
.ing-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 12rpx;
  padding: 0 24rpx 20rpx;
}
.ing-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 16rpx 4rpx; background: #fff; border-radius: 16rpx;
  border: 2rpx solid #F0F0F0; position: relative;
}
.ing-item.selected { border-color: #E94560; background: rgba(233,69,96,0.04); }
.ing-item:active { transform: scale(0.95); }
.ing-icon { width: 48rpx; height: 48rpx; margin-bottom: 6rpx; }
.ing-img { width: 100%; height: 100%; }
.ing-name { font-size: 20rpx; color: #2D3436; text-align: center; }
.ing-check {
  position: absolute; top: 6rpx; right: 6rpx;
  width: 28rpx; height: 28rpx; border-radius: 50%;
  background: #E94560; color: #fff; font-size: 16rpx;
  display: flex; align-items: center; justify-content: center;
}

/* 操作按钮 */
.actions { display: flex; gap: 12rpx; padding: 0 24rpx 20rpx; }
.action-btn {
  flex: 1; background: #E94560; color: #fff; border-radius: 16rpx;
  padding: 18rpx; text-align: center; font-size: 26rpx; font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(233,69,96,0.25);
}
.action-btn:active { transform: scale(0.96); }
.action-btn.secondary {
  background: #fff; color: #4ECDC4; border: 2rpx solid #4ECDC4;
  box-shadow: none;
}

/* 结果区 */
.results { padding: 0 24rpx; }
.results-header { margin-bottom: 16rpx; }
.results-title { font-size: 28rpx; font-weight: 600; color: #2D3436; }

.result-card { margin: 0 0 16rpx; }
.result-card.can-cook { border-left: 6rpx solid #4ECDC4; }

.result-top { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.result-cover { width: 100rpx; height: 100rpx; border-radius: 16rpx; background: #F8F9FA; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
.rc-img { width: 80rpx; height: 80rpx; }
.result-info { flex: 1; }
.result-name { font-size: 28rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 4rpx; }
.result-meta { display: flex; gap: 16rpx; font-size: 22rpx; color: #636E72; }
.result-actions { display: flex; flex-direction: column; align-items: flex-end; gap: 8rpx; }
.fav-btn { font-size: 32rpx; }
.match-badge { font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 100rpx; }
.match-badge.perfect { background: #E8F8F5; color: #4ECDC4; }
.match-badge.partial { background: #FFF8E1; color: #FFB300; }

/* 用料 */
.sub-title { font-size: 24rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 10rpx; }
.ing-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.ing-tag { font-size: 22rpx; background: #F8F9FA; color: #636E72; padding: 6rpx 14rpx; border-radius: 100rpx; }

/* 缺少食材 */
.missing { margin-top: 12rpx; font-size: 24rpx; }
.missing-label { color: #E94560; font-weight: 500; }
.missing-items { color: #636E72; }

/* 步骤 */
.steps { margin-top: 16rpx; border-top: 1rpx solid #F0F0F0; padding-top: 12rpx; }
.steps-toggle { font-size: 24rpx; color: #E94560; padding: 8rpx 0; }
.steps-content { margin-top: 12rpx; }
.step-item { display: flex; gap: 12rpx; margin-bottom: 12rpx; }
.step-num { width: 36rpx; height: 36rpx; border-radius: 50%; background: #E94560; color: #fff; font-size: 20rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-weight: 600; }
.step-txt { font-size: 26rpx; color: #2D3436; line-height: 1.6; flex: 1; }

/* 视频 */
.video-section { margin-top: 16rpx; border-top: 1rpx solid #F0F0F0; padding-top: 12rpx; }
.video-card { display: flex; gap: 14rpx; background: #F8F9FA; border-radius: 14rpx; padding: 12rpx; }
.video-card:active { background: #EDEDED; }
.vid-thumb { position: relative; width: 160rpx; height: 100rpx; border-radius: 10rpx; overflow: hidden; flex-shrink: 0; }
.vid-img { width: 100%; height: 100%; }
.vid-play { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 40rpx; height: 40rpx; background: rgba(0,0,0,0.5); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 20rpx; }
.vid-dur { position: absolute; bottom: 4rpx; right: 4rpx; background: rgba(0,0,0,0.65); color: #fff; font-size: 16rpx; padding: 2rpx 6rpx; border-radius: 4rpx; }
.vid-info { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.vid-title { font-size: 24rpx; color: #2D3436; font-weight: 500; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 4rpx; }
.vid-sub { font-size: 20rpx; color: #636E72; }

/* 弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; display: flex; align-items: center; justify-content: center; }
.modal { background: #fff; border-radius: 24rpx; padding: 28rpx; width: 620rpx; max-height: 80vh; }
.modal-title { font-size: 30rpx; font-weight: 600; color: #2D3436; display: block; margin-bottom: 16rpx; }
.modal-body { max-height: 50vh; }
.modal-text { font-size: 26rpx; color: #2D3436; line-height: 1.7; white-space: pre-wrap; }
.modal-btns { display: flex; gap: 16rpx; margin-top: 20rpx; }
.modal-btn { flex: 1; padding: 16rpx; border-radius: 16rpx; text-align: center; font-size: 28rpx; font-weight: 500; }
.modal-btn.cancel { background: #F8F9FA; color: #636E72; }
.modal-btn.confirm { background: #E94560; color: #fff; }
