<!-- 冰箱页面主容器 -->
<view class="container">
  <!-- 已选食材区域 -->
  <view class="selected-section card">
    <view class="section-header">
      <text class="section-title">🧊 我的冰箱里有</text>
      <text class="clear-btn" bindtap="onClearAll" wx:if="{{selectedIngredients.length > 0}}">清空</text>
    </view>
    <view class="selected-list" wx:if="{{selectedIngredients.length > 0}}">
      <view
        class="selected-tag"
        wx:for="{{selectedIngredients}}"
        wx:key="*this"
        bindtap="onRemoveIngredient"
        data-name="{{item}}"
      >
        <text>{{item}} ✕</text>
      </view>
    </view>
    <text class="placeholder-text" wx:if="{{selectedIngredients.length === 0}}">点击下方食材添加到冰箱</text>
  </view>

  <!-- 搜索食材输入框 -->
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索食材"
      value="{{keyword}}"
      bindinput="onSearchInput"
      bindconfirm="onSearchIngredient"
      confirm-type="search"
    />
  </view>

  <!-- 食材分类标签栏 -->
  <scroll-view scroll-x class="category-scroll" enable-flex>
    <view
      class="category-tab {{activeCategory === cat ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="*this"
      bindtap="onCategoryChange"
      data-cat="{{item}}"
    >
      <text>{{item}}</text>
    </view>
  </scroll-view>

  <!-- 食材网格：手绘图标 -->
  <view class="ingredient-grid">
    <view
      class="ingredient-item {{selectedMap[item.name] ? 'selected' : ''}}"
      wx:for="{{ingredients}}"
      wx:key="name"
      bindtap="onToggleIngredient"
      data-name="{{item.name}}"
    >
      <view class="ingredient-icon">
        <image src="{{item.icon}}" mode="aspectFit" class="ingredient-img" />
      </view>
      <text class="ingredient-name">{{item.name}}</text>
      <view class="check-mark" wx:if="{{selectedMap[item.name]}}">
        <text>✓</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮区 -->
  <view class="action-buttons" wx:if="{{selectedIngredients.length > 0}}">
    <view class="btn-ai" bindtap="onSearchRecipes">
      <text>{{isSearching ? '🤖 搜索中...' : '🤖 推荐菜谱 (' + selectedIngredients.length + ')'}}</text>
    </view>
    <view class="btn-shopping" bindtap="onShowShoppingList" wx:if="{{hasSearched}}">
      <text>📝 购物清单</text>
    </view>
  </view>

  <!-- 推荐结果区域 -->
  <view class="results-section" wx:if="{{hasSearched}}">
    <view class="section-header">
      <text class="section-title">🤖 AI 推荐 ({{results.length}})</text>
    </view>

    <view wx:if="{{results.length > 0}}">
      <view
        class="result-card card {{item.missing.length === 0 ? 'can-cook' : ''}} {{item.missing.length === 1 ? 'almost' : ''}}"
        wx:for="{{results}}"
        wx:key="name"
      >
        <!-- 菜谱头部 -->
        <view class="result-header">
          <view class="result-cover">
            <image src="{{item.coverIcon}}" mode="aspectFit" class="cover-img" />
          </view>
          <view class="result-info">
            <text class="result-name">{{item.name}}</text>
            <view class="result-meta">
              <text wx:if="{{item.cookTime}}">⏱ {{item.cookTime}}分钟</text>
              <text wx:if="{{item.calories}}">🔥 {{item.calories}}kcal</text>
            </view>
          </view>
          <view class="header-actions">
            <text class="fav-btn" bindtap="onToggleFavorite" data-index="{{index}}">{{item.isFavorited ? '❤️' : '🤍'}}</text>
            <view class="match-badge {{item.missing.length === 0 ? 'perfect' : 'partial'}}">
              <text class="match-label">{{item.missing.length === 0 ? '✅ 能做' : '差' + item.missing.length + '种'}}</text>
            </view>
          </view>
        </view>

        <!-- 用料清单 -->
        <view class="ingredients-list" wx:if="{{item.ingredients.length > 0}}">
          <text class="sub-title">📋 用料</text>
          <view class="ingredient-tags">
            <text class="ing-tag" wx:for="{{item.ingredients}}" wx:for-item="ing" wx:key="name">{{ing.name}} {{ing.amount}}</text>
          </view>
        </view>

        <!-- 缺少食材 -->
        <view class="missing-section" wx:if="{{item.missing.length > 0}}">
          <text class="missing-label">还差：</text>
          <text class="missing-items">{{item.missingText}}</text>
          <text class="almost-hint" wx:if="{{item.missing.length === 1}}"> ⭐ 只差一步！</text>
        </view>

        <!-- 步骤预览（可展开） -->
        <view class="steps-section" wx:if="{{item.steps.length > 0}}">
          <view class="steps-toggle" bindtap="onToggleSteps" data-index="{{index}}">
            <text>{{expandedSteps === index ? '🔽 收起步骤' : '▶️ 查看步骤'}}</text>
          </view>
          <view class="steps-content" wx:if="{{expandedSteps === index}}">
            <view class="step-item" wx:for="{{item.steps}}" wx:for-item="step" wx:for-index="sidx" wx:key="*this">
              <text class="step-num">{{sidx + 1}}</text>
              <text class="step-text">{{step}}</text>
            </view>
          </view>
        </view>

        <!-- 视频教程 -->
        <view class="video-section" wx:if="{{item.videos && item.videos.length > 0}}">
          <view class="video-card" bindtap="onVideoTap" data-video="{{item.videos[0]}}">
            <view class="video-thumb">
              <image wx:if="{{item.videos[0].cover}}" src="{{item.videos[0].cover}}" mode="aspectFill" class="video-thumb-img" />
              <view class="video-play-btn"><text>▶</text></view>
              <text class="video-time" wx:if="{{item.videos[0].duration}}">{{item.videos[0].duration}}</text>
            </view>
            <view class="video-detail">
              <text class="video-title">{{item.videos[0].title}}</text>
              <text class="video-info-text">{{item.videos[0].author}} · {{item.videos[0].playText || ''}}</text>
              <text class="video-hint">📺 点击观看教程</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{results.length === 0 && !isSearching}}">
      <text class="empty-emoji">😅</text>
      <text class="empty-text">AI 暂无推荐</text>
      <text class="empty-hint">试试选择更多食材？</text>
    </view>
  </view>

  <!-- 购物清单弹窗 -->
  <view class="modal-mask" wx:if="{{showShoppingList}}" bindtap="onHideShoppingList">
    <view class="modal" catchtap>
      <text class="modal-title">📝 购物清单</text>
      <scroll-view scroll-y class="shopping-content">
        <text class="shopping-text">{{shoppingList}}</text>
      </scroll-view>
      <view class="modal-btns">
        <view class="modal-btn cancel" bindtap="onHideShoppingList">
          <text>关闭</text>
        </view>
        <view class="modal-btn confirm" bindtap="onCopyShoppingList">
          <text>📋 复制</text>
        </view>
      </view>
    </view>
  </view>
</view>
