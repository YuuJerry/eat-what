<!-- 冰箱页面主容器 -->
<view class="container">
  <!-- 已选食材区域 -->
  <view class="selected-section card">
    <view class="section-header">
      <text class="section-title">🧊 我的冰箱里有</text>
      <text class="clear-btn" bindtap="onClearAll" wx:if="{{selectedIngredients.length > 0}}">清空</text>
    </view>
    <view class="selected-list" wx:if="{{selectedIngredients.length > 0}}">
      <view
        class="selected-tag"
        wx:for="{{selectedIngredients}}"
        wx:key="*this"
        bindtap="onRemoveIngredient"
        data-name="{{item}}"
      >
        <text>{{item}} ✕</text>
      </view>
    </view>
    <text class="placeholder-text" wx:if="{{selectedIngredients.length === 0}}">点击下方食材添加到冰箱</text>
  </view>

  <!-- 搜索食材输入框 -->
  <view class="search-bar">
    <input
      class="search-input"
      placeholder="搜索食材"
      value="{{keyword}}"
      bindinput="onSearchInput"
      bindconfirm="onSearchIngredient"
      confirm-type="search"
    />
  </view>

  <!-- 食材分类标签栏 -->
  <scroll-view scroll-x class="category-scroll" enable-flex>
    <view
      class="category-tab {{activeCategory === cat ? 'active' : ''}}"
      wx:for="{{categories}}"
      wx:key="*this"
      bindtap="onCategoryChange"
      data-cat="{{item}}"
    >
      <text>{{item}}</text>
    </view>
  </scroll-view>

  <!-- 食材网格：手绘图标 -->
  <view class="ingredient-grid">
    <view
      class="ingredient-item {{selectedIngredients.includes(item.name) ? 'selected' : ''}}"
      wx:for="{{ingredients}}"
      wx:key="name"
      bindtap="onToggleIngredient"
      data-name="{{item.name}}"
    >
      <view class="ingredient-icon">
        <image src="{{item.icon}}" mode="aspectFit" class="ingredient-img" />
      </view>
      <text class="ingredient-name">{{item.name}}</text>
      <view class="check-mark" wx:if="{{selectedIngredients.includes(item.name)}}">
        <text>✓</text>
      </view>
    </view>
  </view>

  <!-- 确定按钮 -->
  <view class="search-action" wx:if="{{selectedIngredients.length > 0}}">
    <view class="btn-primary search-recipes-btn" bindtap="onSearchRecipes">
      <text>{{isSearching ? '搜索中...' : '🍳 确定并推荐 (' + selectedIngredients.length + ')'}}</text>
    </view>
  </view>

  <!-- 推荐结果区域 -->
  <view class="results-section" wx:if="{{hasSearched}}">
    <view class="section-header">
      <text class="section-title">🎯 推荐菜谱 ({{results.length}})</text>
      <text class="searching-hint" wx:if="{{isSearching}}">搜索中...</text>
    </view>

    <view wx:if="{{results.length > 0}}">
      <view
        class="result-card card {{item.matchRate === 100 ? 'can-cook' : ''}} {{item.missing.length === 1 ? 'almost' : ''}}"
        wx:for="{{results}}"
        wx:key="_id"
        bindtap="onResultTap"
        data-id="{{item._id}}"
      >
        <view class="result-header">
          <view class="result-cover">
            <image src="{{item.coverIcon}}" mode="aspectFit" class="cover-img" />
          </view>
          <view class="result-info">
            <text class="result-name">{{item.name}}</text>
            <view class="result-meta">
              <text>⏱ {{item.cookTime}}分钟</text>
              <text wx:if="{{item.calories}}">🔥 {{item.calories}}kcal</text>
            </view>
          </view>
          <view class="match-badge {{item.matchRate === 100 ? 'perfect' : 'partial'}}">
            <text class="match-rate">{{item.matchRate}}%</text>
            <text class="match-label">{{item.matchRate === 100 ? '能做！' : '匹配'}}</text>
          </view>
        </view>
        <view class="result-detail">
          <text class="owned-text">已有 {{item.ownedCount}}/{{item.totalCount}} 种食材</text>
          <view class="missing-list" wx:if="{{item.missing.length > 0}}">
            <text class="missing-label">还差：</text>
            <text class="missing-items">{{item.missing.join('、')}}</text>
          </view>
          <text class="almost-hint" wx:if="{{item.missing.length === 1}}">⭐ 只差一步就能做！</text>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{results.length === 0 && !isSearching}}">
      <text class="empty-emoji">😅</text>
      <text class="empty-text">没有找到匹配的菜谱</text>
      <text class="empty-hint">试试选择更多食材？</text>
    </view>
  </view>
</view>
